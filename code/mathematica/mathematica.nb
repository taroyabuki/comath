\>", "Input",ExpressionUUID->"d3b6e35f-2f7e-4e2d-88a6-6335212061d3"],

Cell["Reduce[c1 a1 + c2 a2 == {0, 0}]", "Input",ExpressionUUID->"dc81fb3b-0f6c-49cb-b9b4-8b6ea45a22f0"],

Cell["\<\
A = {{1, 0, 1}, {1, 1, 0}, {0, 1, -1}};
ResourceFunction[\"ColumnSpace\"][A][\"Basis\"]\
\>", "Input",ExpressionUUID->"58e2028a-4085-40e7-94b5-34de65da6798"],

Cell["\<\
A = {{1, 0, 1}, {1, 1, 0}, {0, 1, -1}};
tmp = ResourceFunction[\"ColumnSpace\"][A];
basis = Orthogonalize[tmp[\"Basis\"]]\
\>", "Input",ExpressionUUID->"d560281f-ea71-41ed-91a7-6704b070c3aa"],

Cell["\<\
Q = Transpose[basis];
Transpose[Q] . Q\
\>", "Input",ExpressionUUID->"132f94f2-84c2-4614-8fd2-03aae18cc0d0"],

Cell["\<\
A = {{1, 0, 1}, {1, 1, 0}, {0, 1, -1}};
{Qt, R} = QRDecomposition[A]; Q = Transpose[Qt];
{MatrixForm[Q], MatrixForm[R], A == Q . R}\
\>", "Input",ExpressionUUID->"91733a7c-5588-4cf8-b37d-7fb2a7c88b61"],

Cell["\<\
A = {{1, 0}, {1, 1}, {0, 1}};
NullSpace[Transpose[A]]\
\>", "Input",ExpressionUUID->"8c3eaf28-ccf4-4fe1-80a7-e85077d7615d"],

Cell["\<\
Clear[a, b, c, d, f, s, t, u, x, y];
A = {{a, b}, {c, d}};
f[x_] := A . x
R = ParametricRegion[{x, y}, {{x, s, s + u}, {y, t, t + u}}];
Rp = TransformedRegion[R, f];
{RegionMeasure[Rp], Abs[Det[A]] u^2}\
\>", "Input",ExpressionUUID->"8985e035-a986-433f-b09f-aa04f15ece95"]
}, Closed]],

Cell[CellGroupData[{

Cell["19 \:56fa\:6709\:5024\:3068\:56fa\:6709\:30d9\:30af\:30c8\:30eb", \
"Chapter",ExpressionUUID->"ef19e84e-73bb-4065-99a2-e220d0263627"],

Cell["\<\
A = {{2, 1}, {4, -1}};
eigs = Eigensystem[A]\
\>", "Input",ExpressionUUID->"52f3c25c-6cd0-4954-9442-0a23e43ca59a"],

Cell["Solve[Det[x IdentityMatrix[2] - A] == 0, x]", "Input",ExpressionUUID->"e1d05360-56d1-4862-966a-d147ed526b2c"],

Cell["\<\
Clear[x, y]; Reduce[(3 IdentityMatrix[2] - A) . {x, y} == {0, 0}, {x, y}]\
\>", "Input",ExpressionUUID->"3e7ae212-9bc7-46ef-b358-17897ff61026"],

Cell["\<\
S = {{2, 2, -2}, {2, 5, -4}, {-2, -4, 5}};
{Q, L, V} = SingularValueDecomposition[S];
{MatrixForm[Q], MatrixForm[L],
 S == Q . L . Transpose[Q], S == V . L . Transpose[V]}\
\>", "Input",ExpressionUUID->"3dfe1789-15fd-4b85-bd78-b194e62a3906"],

Cell["\<\
S = {{2, 2, -2}, {2, 5, -4}, {-2, -4, 5}};
{vals, vecs} = Eigensystem[S];      (* 1 *)
Q = Transpose[Orthogonalize[vecs]]; (* 2, 3 *)
L = DiagonalMatrix[vals];           (* 4 *)
{MatrixForm[Q], MatrixForm[L], S == Q . L . Transpose[Q]}\
\>", "Input",ExpressionUUID->"0ce33f36-a0f2-4c35-9294-98c377406e83"],

Cell["PositiveSemidefiniteMatrixQ[{{4, 2}, {2, 1}}]", "Input",ExpressionUUID->"77332e41-5753-4366-b64d-68506658ce03"],

Cell["\<\
A = {{4, 2}, {2, 1}};
AllTrue[Eigenvalues[A], NonNegative]\
\>", "Input",ExpressionUUID->"26c9a5f1-3f52-4da0-ae22-0bc367344343"],

Cell["\<\
A = {{46, 46}, {46, 86}};
{v1, v2} = Eigenvectors[N[A], 1][[1]]\
\>", "Input",ExpressionUUID->"16430b74-2d31-4fed-83a4-eec4a4ed8af2"],

Cell["\<\
x1 = {1, 3, 6, 10}; y = {7, 1, 6, 14};
X = Transpose[{x1 - Mean[x1], y - Mean[y]}];
A = Transpose[X] . X\
\>", "Input",ExpressionUUID->"d517ea65-65c4-4266-8b36-6db227b06975"],

Cell["Reduce[v1 (yp - Mean[y]) == v2 (xp - Mean[x1]), yp] // N", "Input",ExpressionUUID->"42576ec4-0c7b-4eb7-9ff3-ba52e37d6bf8"],

Cell["\<\
