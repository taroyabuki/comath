V[[All, 1]] // N\
\>", "Input",ExpressionUUID->"b8241587-e198-43bc-b01a-d905e3a643e5"]
}, Closed]],

Cell[CellGroupData[{

Cell["20 \:7279\:7570\:5024\:5206\:89e3\:3068\:7591\:4f3c\:9006\:884c\:5217", \
"Chapter",ExpressionUUID->"86a0f7ca-c3da-42ce-86f1-03f6599a13ab"],

Cell["\<\
A = {{1, 0}, {1, 1}, {0, 1}};
{U, S, V} = SingularValueDecomposition[A];
{MatrixForm[U], MatrixForm[S], MatrixForm[Transpose[V]],
 MatrixForm[U . S . Transpose[V]]}\
\>", "Input",ExpressionUUID->"ec2f0cfe-bd21-43ba-a4c2-fe7a59b56288"],

Cell["\<\
A = {{1, 0}, {1, 1}, {0, 1}};
G = Transpose[A] . A;                                    (* 1 *)
{vals, vecs} = Eigensystem[G];                           (* 2 *)
s = Sqrt[Select[vals, Positive]]; S = DiagonalMatrix[s]; (* 3 *)
r = Length[s];                                           (* 4 *)
Vt = Orthogonalize[Take[vecs, r]]; V = Transpose[Vt];    (* 5 *)
U = A . V . Inverse[S];                                  (* 6 *)
{MatrixForm[U], MatrixForm[S], MatrixForm[Vt], MatrixForm[U . S . Vt]}\
\>", "Input",ExpressionUUID->"43d83fe8-91b6-497d-8bc7-cb96aa84259b"],

Cell["\<\
A = {{1, 0}, {1, 1}, {0, 1}}; b = {2, 0, 2};
PseudoInverse[A] . b\
\>", "Input",ExpressionUUID->"31d1da3e-edb2-4c6e-8fc2-88213861250a"]
}, Closed]]
