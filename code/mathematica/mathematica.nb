\>", "Input",ExpressionUUID->"74a94063-ca9e-4c08-9c5a-322b26b222dc"]
}, Closed]],

Cell[CellGroupData[{

Cell["20 \:7279\:7570\:5024\:5206\:89e3\:3068\:7591\:4f3c\:9006\:884c\:5217", \
"Chapter",ExpressionUUID->"40a8693d-d437-4c59-8ae1-21da2b0f1833"],

Cell["\<\
A = {{1, 0}, {1, 1}, {0, 1}};
{U, S, V} = SingularValueDecomposition[A]; Vt = Transpose[V];
{MatrixForm[U], MatrixForm[S], MatrixForm[Vt], A == U . S . Vt}\
\>", "Input",ExpressionUUID->"2a21d2b6-ff65-4aa5-b80a-063cd1780cfa"],

Cell["\<\
A = {{1, 0}, {1, 1}, {0, 1}};
G = Transpose[A] . A;                                    (* 1 *)
{vals, vecs} = Eigensystem[G];                           (* 2 *)
s = Sqrt[Select[vals, Positive]]; S = DiagonalMatrix[s]; (* 3 *)
r = Length[s];                                           (* 4 *)
Vt = Orthogonalize[Take[vecs, r]]; V = Transpose[Vt];    (* 5 *)
U = A . V . Inverse[S];                                  (* 6 *)
{MatrixForm[U], MatrixForm[S], MatrixForm[Vt], A == U . S . Vt}\
\>", "Input",ExpressionUUID->"4a9b60d7-f2ef-41cc-ba0b-12d0d12a339f"],

Cell["\<\
A = {{1, 0}, {1, 1}, {0, 1}}; b = {2, 0, 2};
PseudoInverse[A] . b\
\>", "Input",ExpressionUUID->"f9fcfb2b-93ff-4db3-a456-cfb6d02bd5e0"]
}, Closed]]
