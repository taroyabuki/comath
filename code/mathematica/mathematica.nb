   Distributed[U, distU]];
tmp = Distributed[{X, Y}, distXY];
Table[Probability[And[X <= x, Y <= y], tmp], {x, 0, 1}, {y, 0, 2}] ==
 Table[Probability[X <= x, tmp] Probability[Y <= y, tmp],
