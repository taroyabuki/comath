Cell["\<\
line = Module[{x1, y}, ImplicitRegion[y == b0 + b1 x1, {x1, y}]];
L = Sum[RegionDistance[line, p]^2, {p, Thread[{x1, y}]}];
Minimize[L, {b0, b1}] // Simplify // N\
\>", "Input",ExpressionUUID->"755d28ae-601b-4b98-8a90-b4d93b3c8fad"],

Cell["\<\
data = {{1, 2, 3}, {1, 3, 6}, {2, 5, 3}, {3, 7, 6}};
X = DesignMatrix[data, {X1, X2}, {X1, X2}];
y = data[[All, -1]];
Inverse[Transpose[X] . X] . Transpose[X] . y\
\>", "Input",ExpressionUUID->"55860255-ec52-47de-ade6-9237062e4c5d"],

Cell["PseudoInverse[X] . y", "Input",ExpressionUUID->"996a9d92-2fcd-4f57-b90a-19b01000a2f7"],

Cell["\<\
b = {b0, b1, b2};
L = (y - X . b) . (y - X . b);
Reduce[{D[L, {b}] == {0, 0, 0}}]\
\>", "Input",ExpressionUUID->"4a44977d-5353-4f9c-ba94-acbec5641edc"],

Cell["\<\
D[L, {b}] == -2 Transpose[X] . y + 2 Transpose[X] . X . b // Simplify\
\>", "Input",ExpressionUUID->"628ecd61-f24f-4dfb-8264-ba354a1695ae"],

Cell["\<\
data = {{1, 2, 3}, {1, 3, 6}, {2, 5, 3}, {3, 7, 6}};
