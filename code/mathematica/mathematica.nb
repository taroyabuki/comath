Cell["\<\
Needs[\"HypothesisTesting`\"]
MeanCI[x]\
\>", "Input",ExpressionUUID->"7b31105b-a667-4b52-950a-bc1cea20470c"],

Cell["Clear[mu0]; Reduce[a <= t <= b, mu0]", "Input",ExpressionUUID->"e00b633d-d719-4fc4-ab5e-d61d342d3f8e"],

Cell["\<\
dist = StudentTDistribution[n - 1];
Reduce[InverseCDF[dist, alpha/2] <= t <= InverseCDF[dist, 1 - alpha/2]]\
\>", "Input",ExpressionUUID->"b405cc18-32bd-44ff-84e6-6b73c63240ad"],

Cell["\<\
x = {25, 24, 25, 26}; y = {23, 18, 22, 28, 17, 25, 19, 16};
TTest[{x, y}, 0, AlternativeHypothesis -> \"Greater\",
 VerifyTestAssumptions -> \"EqualVariance\" -> False]\
\>", "Input",ExpressionUUID->"c9fd1a7e-875e-400b-aef3-a7083d2cd7c8"],

Cell["\<\
alpha = 5/100;
m = Length[x]; n = Length[y]; sx2 = Variance[x]; sy2 = Variance[y];
s2 = ((m - 1) sx2 + (n - 1) sy2)/(m + n - 2);
T = (Mean[x] - Mean[y] - d)/Sqrt[s2 (1/m + 1/n)];
t := T /. d -> 0                  (* t\:5024 *)
df = m + n - 2;                   (* \:81ea\:7531\:5ea6 *)
dist := StudentTDistribution[df];
P := 1 - CDF[dist][t];            (* P\:5024 *)
a := InverseCDF[dist, 1 - alpha]; (* \:63a1\:629e\:57df\:306e\:4e0a\:9650 *)
interval := Reduce[T <= a, d]     (* \:4fe1\:983c\:533a\:9593 *)
{t, P, a, interval} // N\
\>", "Input",ExpressionUUID->"49c2de08-c1c8-4c0d-8551-9c7c0b443fda"],

Cell["\<\
T = (Mean[x] - Mean[y] - d)/Sqrt[sx2/m + sy2/n];
df = (sx2/m + sy2/n)^2/((sx2/m)^2/(m - 1) + (sy2/n)^2/(n - 1)) // N;
{t, P, a, interval} // N\
\>", "Input",ExpressionUUID->"56ae3a02-c13b-4fe1-958e-6275feda90e7"],

Cell["\<\
x = {25, 24, 25, 26}; y = {23, 18, 22, 28, 17, 25, 19, 16};
VarianceTest[{x, y}, 1, \"HypothesisTestData\"][\"TestDataTable\"]\
\>", "Input",ExpressionUUID->"bdbd0188-9211-4b3f-a1b1-4e890c11e838"],

Cell["\<\
m = Length[x]; n = Length[y]; dist = FRatioDistribution[m - 1, n - 1];
F = Variance[x]/Variance[y]/r; f = F /. r -> 1;
c = CDF[dist][f];
{f, 2 Min[c, 1 - c]} // N\
\>", "Input",ExpressionUUID->"649d0620-d6e5-4653-9373-b8c7f5085abf"],

Cell["\<\
alpha = 5/100;
{a, b} = InverseCDF[dist, {alpha/2, 1 - alpha/2}] // N\
\>", "Input",ExpressionUUID->"0673a367-2d7a-4e82-b09b-7795d8a32616"],

