FindMinimum[L, {{b0, 0}, {b1, 0}}]\
\>", "Input",ExpressionUUID->"cc6c6c85-8f22-46c9-a512-822c684f157d"],

Cell["Minimize[L, {b0, b1}] (* \:89e3\:6790\:7684\:306a\:7d50\:679c *)", \
"Input",ExpressionUUID->"23d668f4-e4d7-43ca-8201-3c2e699797d2"],

Cell["\<\
L = Total[Abs[e]]; (* \:5dee\:306e\:7d76\:5bfe\:5024\:306e\:548c *)
Minimize[L, {b0, b1}]\
\>", "Input",ExpressionUUID->"6bcd936b-af5f-4a42-90ca-934241981bd1"],

Cell["\<\
e = x1 - (y - b0)/b1;
L = e . e;
Minimize[L, {b0, b1}]\
\>", "Input",ExpressionUUID->"8739ba02-e5d8-4270-bda5-4889082c3b27"],

Cell["\<\
line = Module[{x1, y}, ImplicitRegion[y == b0 + b1 x1, {x1, y}]];
L = Sum[RegionDistance[line, p]^2, {p, Thread[{x1, y}]}];
Minimize[L, {b0, b1}] // Simplify // N\
\>", "Input",ExpressionUUID->"6e2872d8-8583-4bb8-8f75-94f598ab50b9"],

Cell["\<\
data = {{1, 2, 3}, {1, 3, 6}, {2, 5, 3}, {3, 7, 6}};
X = DesignMatrix[data, {X1, X2}, {X1, X2}];
y = data[[All, -1]];
Inverse[Transpose[X] . X] . Transpose[X] . y\
\>", "Input",ExpressionUUID->"1283bf1b-241b-4176-b4b9-c59e5f88f13e"],

Cell["PseudoInverse[X] . y", "Input",ExpressionUUID->"90fb5861-6648-4fa3-b5b7-414cf43afbd3"],

Cell["\<\
b = {b0, b1, b2};
L = (y - X . b) . (y - X . b);
Reduce[{D[L, {b}] == {0, 0, 0}}]\
\>", "Input",ExpressionUUID->"a6597159-58cd-431c-913e-e1af60db3c34"],

Cell["\<\
D[L, {b}] == -2 Transpose[X] . y + 2 Transpose[X] . X . b // Simplify\
\>", "Input",ExpressionUUID->"682b62e1-59ba-49f0-a803-445604d22d96"],

Cell["\<\
data = {{1, 2, 3}, {1, 3, 6}, {2, 5, 3}, {3, 7, 6}};
model = LinearModelFit[data, {X1, X2}, {X1, X2}];
model[\"RSquared\"]\
\>", "Input",ExpressionUUID->"1ff5c943-b723-4f94-964f-e436e590036d"],

Cell["\<\
x1 = {1, 3, 6, 10}; y = {7, 1, 6, 14}; data = Thread[{x1, y}];
X = DesignMatrix[data, X1, X1];
yh = X . PseudoInverse[X] . y;
eh = y - yh; fh = yh - Mean[y]; g = y - Mean[y];
R2 = 1 - eh . eh/g . g; N[R2]\
\>", "Input",ExpressionUUID->"12942455-b446-418d-991b-86b9780ec7dd"],

Cell["\<\
{Mean[eh] == 0,                            (* \:7279\:5fb41 *)
 Mean[yh] == Mean[y],                      (* \:7279\:5fb42 *)
 g . g == fh . fh + eh . eh,               (* \:7279\:5fb43 *)
 R2 == fh . fh/g . g,                      (* \:7279\:5fb44 *)
 R2 == Correlation[y, yh]^2,               (* \:7279\:5fb45 *)
 0 <= R2 <= 1,                             (* \:7279\:5fb46 *)
 Correlation[y, yh] == Correlation[y, x1]} (* \:7279\:5fb47 *)\
\>", "Input",ExpressionUUID->"697f46f4-df5d-4208-b2b6-2d45b470f678"],

Cell["\<\
X = {{1, 1, 2}, {1, 1, 3}, {1, 2, 5}, {1, 3, 7}};
{n, p} = Dimensions[X];
beta = Table[Subscript[\[Beta], i - 1], {i, p}];
epsilon = Table[Subscript[\[Epsilon], i], {i, n}];
Y = X . beta + epsilon;
betah = PseudoInverse[X] . Y // Simplify\
\>", "Input",ExpressionUUID->"ed1ef8a6-9f3f-469f-a87b-7a09bfe4545f"],

Cell["\<\
Clear[sigma];
udist = UniformDistribution[{-Sqrt[3] sigma, Sqrt[3] sigma}];
udists = Table[Distributed[v, udist], {v, epsilon}];
Expectation[betah, udists]\
\>", "Input",ExpressionUUID->"91481ddb-c307-4753-9e34-61578c697da1"],

Cell["\<\
Z = {{1, 0, 0}, {0, 1, 0}, {0, 0, 1}, {0, 0, 0}};
Cz = Inverse[Transpose[Z] . X] . Transpose[Z];
b = Cz . Y;
Expectation[b, udists]\
\>", "Input",ExpressionUUID->"2073e218-8948-4bba-be1b-c91d9b13a80f"],

Cell["\<\
dist1 = TransformedDistribution[b, udists];
dist2 = TransformedDistribution[betah, udists];
Eigenvalues[Covariance[dist1] - Covariance[dist2]]\
\>", "Input",ExpressionUUID->"05fb8bca-baa4-4b0c-b241-d361cc5b7d0b"],

Cell["\<\
Variance[dist1]
Variance[dist2]\
\>", "Input",ExpressionUUID->"7a7a9b2c-16dd-4d97-bc02-80670a9e910d"],

Cell["\<\
ndist = NormalDistribution[0, sigma];
ndists = Table[Distributed[v, ndist], {v, epsilon}];
TransformedDistribution[betah, ndists] ==
 MultinormalDistribution[beta, sigma^2 Inverse[Transpose[X] . X]]\
\>", "Input",ExpressionUUID->"a3120629-4ea8-4e9b-903a-6f937cbe9d5b"],

Cell["\<\
data = {{1, 2, 3}, {1, 3, 6}, {2, 5, 3}, {3, 7, 6}};
model = LinearModelFit[data, {X1, X2}, {X1, X2}];
model[\"EstimatedVariance\"]\
\>", "Input",ExpressionUUID->"f3c08c98-ecf0-4b13-b3d3-937bb542e7c2"],

Cell["\<\
e = Y - X . betah; RSS = e . e;
s2 = RSS/(n - p) // Simplify\
\>", "Input",ExpressionUUID->"3001e844-53cc-4d50-9035-9e6466e0f088"],

Cell["Expectation[s2, udists]", "Input",ExpressionUUID->"cadf6ef4-7f7e-4685-b4b4-c1a804aedeac"],

Cell["\<\
tmp = Block[{sigma = 2},
   dist = TransformedDistribution[(n - p) s2/sigma^2, ndists];
   RandomVariate[dist, 10000]];
cdist = ChiSquareDistribution[n - p];
Show[Histogram[tmp, Automatic, \"PDF\"],
 Plot[PDF[cdist][x], {x, 0, 5}, PlotRange -> {0, 2}]]\
\>", "Input",ExpressionUUID->"2eff9d17-0210-48fb-ba2b-3a4d51ffb416"],

Cell["\<\
n := Length[data]; p := Length[data[[1]]]; Clear[x];
vars := Table[Subscript[x, i], {i, p - 1}]
X := DesignMatrix[data, vars, vars]; y := data[[All, -1]]
yh := X . PseudoInverse[X] . y; e := y - yh;

data = {{1, 2, 3}, {1, 3, 6}, {2, 5, 3}, {3, 7, 6}};
Module[{F, fdist},
  F = Total[(yh - Mean[y])^2]/(p - 1)/(e . e/(n - p));
  fdist = FRatioDistribution[p - 1, n - p];
  {F, 1 - CDF[fdist][F]}] // N\
\>", "Input",ExpressionUUID->"5ce0eef2-8a34-4b56-9116-c5b33e3b8203"],

Cell["\<\
betah := PseudoInverse[X] . y; uh := Transpose[A] . betah
M := Transpose[A] . Inverse[Transpose[X] . X] . A
r := MatrixRank[A]
RSS := e . e; s2 := RSS/(n - p)
F := ((uh - u) . Inverse[M] . (uh - u)/r)/s2
fdist := FRatioDistribution[r, n - p]
pvalue := 1 - CDF[fdist, F]

A = Transpose[{{0, 1, 0}, {0, 0, 1}}]; u = {0, 0};
{F, pvalue} // N\
\>", "Input",ExpressionUUID->"55951615-916d-4138-8c5d-f187a8ac7244"],

Cell["\<\
model := LinearModelFit[data, vars, vars]
model[\"ParameterTable\"]\
\>", "Input",ExpressionUUID->"4efa4dbe-7efa-4f6b-a664-30b278d6c7e5"],

Cell["\<\
u = {0};
A = Transpose[{{1, 0, 0}}]; pvalue // N (* k = 0 *)
A = Transpose[{{0, 1, 0}}]; pvalue // N (* k = 1 *)
A = Transpose[{{0, 0, 1}}]; pvalue // N (* k = 2 *)\
\>", "Input",ExpressionUUID->"28ce4048-088d-404b-85b7-ce9589f65c2d"],

Cell["\<\
s := Sqrt[s2 Diagonal[Inverse[Transpose[X] . X]]]
s // N\
\>", "Input",ExpressionUUID->"0adcd3ad-c96f-45c7-8213-a464d44a162e"],

Cell["\<\
t := betah/s
t // N\
\>", "Input",ExpressionUUID->"5d3641ed-9d00-42d5-be1b-4f8c79913a4a"],

Cell["\<\
tdist := StudentTDistribution[n - p]
Table[2 Min[CDF[tdist][v], 1 - CDF[tdist][v]], {v, t}] // N\
\>", "Input",ExpressionUUID->"c197146d-fb0a-4f93-af65-d82085e2a19b"],

Cell["\<\
data = Transpose[{{35, 45, 55, 65, 75}, {114, 124, 143, 158, 166}}];
alpha = 5/100; level := ConfidenceLevel -> 1 - alpha
model[\"ParameterConfidenceIntervalTable\", level]\
\>", "Input",ExpressionUUID->"e6e501a4-c0f5-42cc-9f0f-9b4b81c4280a"],

Cell["\<\
tmp = InverseCDF[tdist, 1 - alpha/2];
{betah - s tmp, betah + s tmp} // Transpose // N\
\>", "Input",ExpressionUUID->"44b2e3ae-ea0a-4de3-93b2-0255680920b9"],

Cell["\<\
cond := F <= InverseCDF[fdist, 1 - alpha]
confint := Reduce[cond]
A = Transpose[{{1, 0}}]; u = {beta0}; confint // N (* k = 0 *)
A = Transpose[{{0, 1}}]; u = {beta1}; confint // N (* k = 1 *)\
\>", "Input",ExpressionUUID->"a737b2a3-cb9a-4f08-bebe-6a48789c46d4"],

Cell["\<\
tmp = model[\"ParameterConfidenceIntervals\", level]
g1 = Graphics[{Gray, Apply[Rectangle, Transpose[tmp]]}];
g2 = Graphics[model[\"ParameterConfidenceRegion\", level]];
Show[g1, g2, AspectRatio -> 1, Frame -> True]\
\>", "Input",ExpressionUUID->"b61014ab-e81a-4c4c-b518-8f7beb98675f"],

Cell["\<\
A = {{1, 0}, {0, 1}}; u = {beta0, beta1};
g3 = RegionPlot[ImplicitRegion[N[cond], Evaluate[u]]];
Show[g1, g3, AspectRatio -> 1, Frame -> True]\
\>", "Input",ExpressionUUID->"9d82e1ae-544a-4775-b25c-00b06560627d"],

Cell["\<\
data = Transpose[
   {{35, 45, 55, 65, 75}, {2, 3, 5, 7, 11}, {114, 124, 143, 158, 166}}];
data0 = data[[All, {1, 3}]];
model0 = LinearModelFit[data0, X1, X1];
model1 = LinearModelFit[data, {X1, X2}, {X1, X2}];
{{model0[\"RSquared\"], model0[\"AdjustedRSquared\"]},
 {model1[\"RSquared\"], model1[\"AdjustedRSquared\"]}} // TableForm\
\>", "Input",ExpressionUUID->"213b8d3c-4590-4b82-b34b-2a2a203c22d5"],

Cell["\<\
Module[{n, p, r, AR20, AR21, RSS0, RSS1, S, F}, (* S\:306f\:5168\:5909\:52d5 *)
 AR20 = 1 - RSS0/(n - (p - r))/(S/(n - 1));
 AR21 = 1 - RSS1/(n - p)/(S/(n - 1));
 F = (RSS0 - RSS1)/r/(RSS1/(n - p));
 FullSimplify[Reduce[Equivalent[AR21 <= AR20, F <= 1], Reals],
  And[S > 0, RSS0 > 0, RSS1 > 0, n > p > 1, r > 0]]]\
