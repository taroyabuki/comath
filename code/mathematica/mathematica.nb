eigs = Eigensystem[A]\
\>", "Input",ExpressionUUID->"155b6aa4-3112-4333-91bc-89402a6701b1"],

Cell["Solve[Det[x IdentityMatrix[2] - A] == 0, x]", "Input",ExpressionUUID->"46f840b5-93d4-4e0c-b9ad-394e078ec2ae"],

Cell["\<\
Clear[x, y]; Reduce[(3 IdentityMatrix[2] - A) . {x, y} == {0, 0}, {x, y}]\
\>", "Input",ExpressionUUID->"e6e0916a-fd30-4201-967c-c10f60711fbd"],

Cell["\<\
S = {{2, 2, -2}, {2, 5, -4}, {-2, -4, 5}};
{Q, L, V} = SingularValueDecomposition[S];
{MatrixForm[Q], MatrixForm[L], MatrixForm[Q . L . Transpose[Q]]}\
\>", "Input",ExpressionUUID->"d781ea0f-e0bb-4d26-98f5-7eb867cff384"],

Cell["\<\
S = {{2, 2, -2}, {2, 5, -4}, {-2, -4, 5}};
{vals, vecs} = Eigensystem[S];      (* \:56fa\:6709\:5024\:30fb\:56fa\:6709\
\:30d9\:30af\:30c8\:30eb *)
Q = Transpose[Orthogonalize[vecs]]; (* \:6b63\:898f\:76f4\:4ea4\:306a\:56fa\
\:6709\:30d9\:30af\:30c8\:30eb *)
L = DiagonalMatrix[vals];           (* \:5bfe\:89d2\:884c\:5217 *)
{MatrixForm[Q], MatrixForm[L], MatrixForm[Q . L . Transpose[Q]]}\
\>", "Input",ExpressionUUID->"681c2a8c-e56e-4f6a-baaf-f4cb705b4e4d"],

Cell["PositiveSemidefiniteMatrixQ[{{4, 2}, {2, 1}}]", "Input",ExpressionUUID->"57c2b4d5-f99c-434d-9a23-cf3b4fade105"],

Cell["\<\
A = {{4, 2}, {2, 1}};
AllTrue[Eigenvalues[A], NonNegative]\
\>", "Input",ExpressionUUID->"659976a2-8644-4594-8436-372b71587138"],

Cell["\<\
A = {{46, 46}, {46, 86}};
{v1, v2} = Eigenvectors[N[A]][[1]]\
\>", "Input",ExpressionUUID->"112acdc5-f3cc-4090-aa49-d6dd852c7b77"],

Cell["\<\
x1 = {1, 3, 6, 10}; y = {7, 1, 6, 14};
X = Transpose[{x1 - Mean[x1], y - Mean[y]}];
A = Transpose[X] . X\
\>", "Input",ExpressionUUID->"6daac6db-85e7-41b3-9986-dfe2de5a8c6c"],

Cell["Reduce[v1 (yp - Mean[y]) == v2 (xp - Mean[x1]), yp] // N", "Input",ExpressionUUID->"f13a77ad-7a4e-412e-bc75-e002dfa3ae50"],

Cell["\<\
