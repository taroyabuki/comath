ResourceFunction[\"LinearlyIndependent\"][{a1, a2}]\
\>", "Input",ExpressionUUID->"624b3181-ef6f-455f-be28-a3f7e2deb896"],

Cell["Reduce[c1 a1 + c2 a2 == {0, 0}]", "Input",ExpressionUUID->"3e665feb-eefb-42c8-8a88-417a85cc6ad5"],

Cell["\<\
