Cell["\<\
data = {{1, 2, 3}, {1, 3, 6}, {2, 5, 3}, {3, 7, 6}};
X = DesignMatrix[data, {X1, X2}, {X1, X2}];
y = data[[All, -1]];
Inverse[Transpose[X] . X] . Transpose[X] . y\
\>", "Input",ExpressionUUID->"fe810565-003f-4f24-88a6-5494e755223b"],

Cell["PseudoInverse[X] . y", "Input",ExpressionUUID->"82e2ef96-9796-4d3b-8de7-8bb459d1ce08"],

Cell["\<\
b = {b0, b1, b2};
L = (y - X . b) . (y - X . b);
Reduce[{D[L, {b}] == {0, 0, 0}}]\
\>", "Input",ExpressionUUID->"cd109f94-df9e-4688-9c14-80246a86e352"],

Cell["\<\
D[L, {b}] == -2 Transpose[X] . y + 2 Transpose[X] . X . b // Simplify\
\>", "Input",ExpressionUUID->"0216269c-1e68-4ca7-8528-f2ee341f9e25"],

Cell["\<\
data = {{1, 2, 3}, {1, 3, 6}, {2, 5, 3}, {3, 7, 6}};
