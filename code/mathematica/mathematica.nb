\>", "Input",ExpressionUUID->"5985edea-daa4-4855-99f1-60f44cd050f6"],

Cell["\<\
x1 = {1, 3, 6, 10}; y = {7, 1, 6, 14}; data = Thread[{x1, y}];
X = DesignMatrix[data, X1, X1];
yh = X . PseudoInverse[X] . y;
eh = y - yh; fh = yh - Mean[y]; g = y - Mean[y];
R2 = 1 - eh . eh/g . g; N[R2]\
\>", "Input",ExpressionUUID->"c99b98d8-3f25-452b-8905-ea2e77efd3f2"],

Cell["\<\
{Mean[eh] == 0,                            (* \:7279\:5fb41 *)
 Mean[yh] == Mean[y],                      (* \:7279\:5fb42 *)
 g . g == fh . fh + eh . eh,               (* \:7279\:5fb43 *)
 R2 == fh . fh/g . g,                      (* \:7279\:5fb44 *)
 R2 == Correlation[y, yh]^2,               (* \:7279\:5fb45 *)
 0 <= R2 <= 1,                             (* \:7279\:5fb46 *)
 Correlation[y, yh] == Correlation[y, x1]} (* \:7279\:5fb47 *)\
\>", "Input",ExpressionUUID->"5740bb22-e2c0-4e7c-a07f-1d3c619f6289"],

Cell["\<\
X = {{1, 1, 2}, {1, 1, 3}, {1, 2, 5}, {1, 3, 7}};
{n, p} = Dimensions[X];
beta = Table[Subscript[\[Beta], i - 1], {i, p}];
epsilon = Table[Subscript[\[Epsilon], i], {i, n}];
Y = X . beta + epsilon;
betah = PseudoInverse[X] . Y // Simplify\
\>", "Input",ExpressionUUID->"b2499980-59f7-49b0-9fc5-97abbbee6540"],

Cell["\<\
Clear[sigma];
udist = UniformDistribution[{-Sqrt[3] sigma, Sqrt[3] sigma}];
udists = Table[Distributed[v, udist], {v, epsilon}];
Expectation[betah, udists]\
\>", "Input",ExpressionUUID->"370c4ce0-8f4d-414d-beab-b6ddca5cb178"],

Cell["\<\
Z = {{1, 0, 0}, {0, 1, 0}, {0, 0, 1}, {0, 0, 0}};
Cz = Inverse[Transpose[Z] . X] . Transpose[Z];
b = Cz . Y;
Expectation[b, udists]\
\>", "Input",ExpressionUUID->"cf3c9fe5-0f4b-4887-a780-34b2e25acd16"],

Cell["\<\
dist1 = TransformedDistribution[b, udists];
dist2 = TransformedDistribution[betah, udists];
Eigenvalues[Covariance[dist1] - Covariance[dist2]]\
\>", "Input",ExpressionUUID->"22d575d9-3868-47c4-a3fd-9f7c6d1ef942"],

Cell["\<\
Variance[dist1]
Variance[dist2]\
\>", "Input",ExpressionUUID->"42c23eae-a420-494f-a87d-4a42ed654c13"],

Cell["\<\
ndist = NormalDistribution[0, sigma];
ndists = Table[Distributed[v, ndist], {v, epsilon}];
TransformedDistribution[betah, ndists] ==
 MultinormalDistribution[beta, sigma^2 Inverse[Transpose[X] . X]]\
\>", "Input",ExpressionUUID->"7aae0d75-dab7-4dab-919a-d4f67a355c61"],

Cell["\<\
data = {{1, 2, 3}, {1, 3, 6}, {2, 5, 3}, {3, 7, 6}};
model = LinearModelFit[data, {X1, X2}, {X1, X2}];
model[\"EstimatedVariance\"]\
\>", "Input",ExpressionUUID->"91d97f68-2d01-4841-8e18-2f556344d639"],

Cell["\<\
e = Y - X . betah; RSS = e . e;
s2 = RSS/(n - p) // Simplify\
\>", "Input",ExpressionUUID->"7c0a609d-ce31-4f5a-9a06-ed71d0806d40"],

Cell["Expectation[s2, udists]", "Input",ExpressionUUID->"8c52b34c-e066-494a-9758-8fb7c37ad671"],

Cell["\<\
tmp = Block[{sigma = 2},
   dist = TransformedDistribution[(n - p) s2/sigma^2, ndists];
   RandomVariate[dist, 10000]];
cdist = ChiSquareDistribution[n - p];
Show[Histogram[tmp, Automatic, \"PDF\"],
 Plot[PDF[cdist][x], {x, 0, 5}, PlotRange -> {0, 2}]]\
\>", "Input",ExpressionUUID->"61f1b6e5-c1ce-4ae4-9920-6911c5e35403"],

Cell["\<\
n := Length[data]; p := Length[data[[1]]]; Clear[x];
vars := Table[Subscript[x, i], {i, p - 1}]
X := DesignMatrix[data, vars, vars]; y := data[[All, -1]]
yh := X . PseudoInverse[X] . y; e := y - yh;

data = {{1, 2, 3}, {1, 3, 6}, {2, 5, 3}, {3, 7, 6}};
Module[{F, fdist},
  F = Total[(yh - Mean[y])^2]/(p - 1)/(e . e/(n - p));
  fdist = FRatioDistribution[p - 1, n - p];
  {F, 1 - CDF[fdist][F]}] // N\
\>", "Input",ExpressionUUID->"ecca17e3-2c64-4cd5-9f58-df2956a59006"],

Cell["\<\
betah := PseudoInverse[X] . y; uh := Transpose[A] . betah
M := Transpose[A] . Inverse[Transpose[X] . X] . A
r := MatrixRank[A]
RSS := e . e; s2 := RSS/(n - p)
F := ((uh - u) . Inverse[M] . (uh - u)/r)/s2
fdist := FRatioDistribution[r, n - p]
pvalue := 1 - CDF[fdist, F]

A = Transpose[{{0, 1, 0}, {0, 0, 1}}]; u = {0, 0};
{F, pvalue} // N\
\>", "Input",ExpressionUUID->"785b3e9b-e75a-44b1-9dd8-6006d7b6d239"],

Cell["\<\
model := LinearModelFit[data, vars, vars]
model[\"ParameterTable\"]\
\>", "Input",ExpressionUUID->"b6644229-a75d-45c0-8255-8fbd4652ba01"],

Cell["\<\
u = {0};
A = Transpose[{{1, 0, 0}}]; pvalue // N (* k = 0 *)
A = Transpose[{{0, 1, 0}}]; pvalue // N (* k = 1 *)
A = Transpose[{{0, 0, 1}}]; pvalue // N (* k = 2 *)\
\>", "Input",ExpressionUUID->"81e29472-3e1c-4e08-b869-2c5c03be7535"],

Cell["\<\
s := Sqrt[s2 Diagonal[Inverse[Transpose[X] . X]]]
s // N\
\>", "Input",ExpressionUUID->"d039f37f-912c-4f4b-be1c-0c7d4a4c1d02"],

Cell["\<\
t := betah/s
t // N\
\>", "Input",ExpressionUUID->"7418a62d-4902-4f5b-a94f-dc220a94ad3a"],

Cell["\<\
tdist := StudentTDistribution[n - p]
Table[2 Min[CDF[tdist][v], 1 - CDF[tdist][v]], {v, t}] // N\
\>", "Input",ExpressionUUID->"bda63267-4a0f-4f80-be48-efef46e605c2"],

Cell["\<\
