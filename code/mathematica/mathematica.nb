\>", "Input",ExpressionUUID->"5a41173f-86b8-4158-8c78-fd43238bacf5"],

Cell["\<\
m = Length[x]; n = Length[y]; dist = FRatioDistribution[m - 1, n - 1];
F = Variance[x]/Variance[y]/r; f = F /. r -> 1;
c = CDF[dist][f];
{f, 2 Min[c, 1 - c]} // N\
\>", "Input",ExpressionUUID->"5c0aef63-f5fb-446e-9218-28c2d1ad6398"],

