Cell["\<\
{uX, uY} = Mean[distXY]; {sX, sY} = StandardDeviation[distXY];
Expectation[{X, Y,           (* \:5e73\:5747 *)
   (X - uX)^2, (Y - uY)^2,   (* \:5206\:6563 *)
   (X - uX) (Y - uY),        (* \:5171\:5206\:6563 *)
   (X - uX) (Y - uY)/sX/sY}, (* \:76f8\:95a2\:4fc2\:6570 *)
