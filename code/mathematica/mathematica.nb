V[[All, 1]] // N\
\>", "Input",ExpressionUUID->"196e5fec-25f0-4402-8576-94b624fe1a00"]
}, Closed]],

Cell[CellGroupData[{

Cell["20 \:7279\:7570\:5024\:5206\:89e3\:3068\:7591\:4f3c\:9006\:884c\:5217", \
"Chapter",ExpressionUUID->"d5592ad5-4c19-4250-bafb-ea8be23c52f3"],

Cell["\<\
A = {{1, 0}, {1, 1}, {0, 1}};
{U, S, V} = SingularValueDecomposition[A]; Vt = Transpose[V];
{MatrixForm[U], MatrixForm[S], MatrixForm[Vt], A == U . S . Vt}\
\>", "Input",ExpressionUUID->"b5539a79-ba43-4670-a72f-397f28226755"],

Cell["\<\
A = {{1, 0}, {1, 1}, {0, 1}};
G = Transpose[A] . A;                                    (* 1 *)
{vals, vecs} = Eigensystem[G];                           (* 2 *)
s = Sqrt[Select[vals, Positive]]; S = DiagonalMatrix[s]; (* 3 *)
r = Length[s];                                           (* 4 *)
Vt = Orthogonalize[Take[vecs, r]]; V = Transpose[Vt];    (* 5 *)
U = A . V . Inverse[S];                                  (* 6 *)
{MatrixForm[U], MatrixForm[S], MatrixForm[Vt], A == U . S . Vt}\
\>", "Input",ExpressionUUID->"d556c443-17e4-4d2e-a20e-7d90e427a1df"],

Cell["\<\
A = {{1, 0}, {1, 1}, {0, 1}}; b = {2, 0, 2};
PseudoInverse[A] . b\
\>", "Input",ExpressionUUID->"7ce3e20d-df77-4ec7-aa83-a1e4ddc892a7"]
}, Closed]]
