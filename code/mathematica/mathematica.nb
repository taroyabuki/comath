\>", "Input",ExpressionUUID->"d149c439-efbb-4009-9b9c-b6c1467649c8"],

Cell["\<\
m = Length[x]; n = Length[y]; dist = FRatioDistribution[m - 1, n - 1];
F = Variance[x]/Variance[y]/r; f = F /. r -> 1;
c = CDF[dist][f];
{f, 2 Min[c, 1 - c]} // N\
\>", "Input",ExpressionUUID->"bbef908f-dfee-46ef-adce-b8070972e986"],

Cell["\<\
