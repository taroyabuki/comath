Cell["\<\
a1 = {3, 1}; a2 = {2, 2};
ResourceFunction[\"LinearlyIndependent\"][{a1, a2}]\
\>", "Input",ExpressionUUID->"696d44bf-d04c-4226-bffb-eb88c7a59922"],

Cell["Reduce[c1 a1 + c2 a2 == {0, 0}]", "Input",ExpressionUUID->"5eff6a38-d8b1-457e-ad15-056189571371"],

Cell["\<\
A = {{1, 0, 1}, {1, 1, 0}, {0, 1, -1}};
ResourceFunction[\"ColumnSpace\"][A][\"Basis\"]\
\>", "Input",ExpressionUUID->"f965aea4-ba5e-4ec0-a4e2-8d3af590840f"],

Cell["\<\
A = {{1, 0, 1}, {1, 1, 0}, {0, 1, -1}};
tmp = ResourceFunction[\"ColumnSpace\"][A];
basis = Orthogonalize[tmp[\"Basis\"]]\
\>", "Input",ExpressionUUID->"b7764636-439f-4de6-bd5d-d17a7ef87d3b"],

Cell["\<\
Q = Transpose[basis];
Transpose[Q] . Q\
\>", "Input",ExpressionUUID->"d8c52609-c6cc-4899-8146-6a0d788630e1"],

Cell["\<\
A = {{1, 0, 1}, {1, 1, 0}, {0, 1, -1}};
{Qt, R} = QRDecomposition[A]; Q = Transpose[Qt];
{MatrixForm[Q], MatrixForm[R], MatrixForm[Q . R]}\
\>", "Input",ExpressionUUID->"34ad0d7b-f8e1-420e-9ec8-2699ae0d1faa"],

Cell["\<\
A = {{1, 0}, {1, 1}, {0, 1}};
NullSpace[Transpose[A]]\
\>", "Input",ExpressionUUID->"352e3ca6-5498-45d8-a315-03e81fc6225b"],

Cell["\<\
Clear[a, b, c, d, f, s, t, u, x, y]; A = {{a, b}, {c, d}};
f[x_] := A . x
R = ParametricRegion[{x, y}, {{x, s, s + u}, {y, t, t + u}}];
Rp = TransformedRegion[R, f];
{RegionMeasure[Rp], Abs[Det[A]] u^2}\
\>", "Input",ExpressionUUID->"8f8b9b0b-5881-4761-b36a-aa64382633e9"]
}, Closed]],

Cell[CellGroupData[{

Cell["19 \:56fa\:6709\:5024\:3068\:56fa\:6709\:30d9\:30af\:30c8\:30eb", \
"Chapter",ExpressionUUID->"2df522db-771a-43d2-9dce-c797208874df"],

Cell["\<\
A = {{2, 1}, {4, -1}};
eigs = Eigensystem[A]\
\>", "Input",ExpressionUUID->"0f1e815a-99cd-486d-8c49-11ab678cc231"],

Cell["Solve[Det[x IdentityMatrix[2] - A] == 0, x]", "Input",ExpressionUUID->"c3633fee-e2c6-4c19-887b-5532f99b0706"],

Cell["\<\
Clear[x, y]; Reduce[(3 IdentityMatrix[2] - A) . {x, y} == {0, 0}, {x, y}]\
\>", "Input",ExpressionUUID->"8d3431c7-31f1-4267-946c-ddd5e5efdb1a"],

Cell["\<\
S = {{2, 2, -2}, {2, 5, -4}, {-2, -4, 5}};
{Q, L, V} = SingularValueDecomposition[S];
{MatrixForm[Q], MatrixForm[L], MatrixForm[Q . L . Transpose[Q]]}\
\>", "Input",ExpressionUUID->"bdd67b08-6b64-445c-bdc0-8e2dd38a37a2"],

Cell["\<\
S = {{2, 2, -2}, {2, 5, -4}, {-2, -4, 5}};
{vals, vecs} = Eigensystem[S];      (* \:56fa\:6709\:5024\:30fb\:56fa\:6709\
\:30d9\:30af\:30c8\:30eb *)
Q = Transpose[Orthogonalize[vecs]]; (* \:6b63\:898f\:76f4\:4ea4\:306a\:56fa\
\:6709\:30d9\:30af\:30c8\:30eb *)
L = DiagonalMatrix[vals];           (* \:5bfe\:89d2\:884c\:5217 *)
{MatrixForm[Q], MatrixForm[L], MatrixForm[Q . L . Transpose[Q]]}\
\>", "Input",ExpressionUUID->"0233f689-abc0-4403-82fd-f45aabfabe7e"],

Cell["PositiveSemidefiniteMatrixQ[{{4, 2}, {2, 1}}]", "Input",ExpressionUUID->"f0527f56-660a-4729-b0db-e84c5378eda1"],

Cell["\<\
A = {{4, 2}, {2, 1}};
AllTrue[Eigenvalues[A], NonNegative]\
\>", "Input",ExpressionUUID->"f08678a1-9f41-4ea9-83c8-1cd01950153d"],

Cell["\<\
A = {{46, 46}, {46, 86}};
{v1, v2} = Eigenvectors[N[A]][[1]]\
\>", "Input",ExpressionUUID->"75a452f2-40d0-443a-95f5-ebe5ab586548"],

Cell["\<\
x1 = {1, 3, 6, 10}; y = {7, 1, 6, 14};
X = Transpose[{x1 - Mean[x1], y - Mean[y]}];
A = Transpose[X] . X\
\>", "Input",ExpressionUUID->"d8ab7b2b-e7b2-4f32-beeb-b167a67f987d"],

Cell["Reduce[v1 (yp - Mean[y]) == v2 (xp - Mean[x1]), yp] // N", "Input",ExpressionUUID->"5953e31e-1fd5-4809-8690-f65c8228d7e5"],

Cell["\<\
