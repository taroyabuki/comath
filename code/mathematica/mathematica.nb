V[[All, 1]] // N\
\>", "Input",ExpressionUUID->"60ce4555-ba38-446a-8343-c9de9a7860e8"]
}, Closed]],

Cell[CellGroupData[{

Cell["20 \:7279\:7570\:5024\:5206\:89e3\:3068\:7591\:4f3c\:9006\:884c\:5217", \
"Chapter",ExpressionUUID->"121233f7-38c4-4d46-9889-4cc859090326"],

Cell["\<\
A = {{1, 0}, {1, 1}, {0, 1}};
{U, S, V} = SingularValueDecomposition[A]; Vt = Transpose[V];
{MatrixForm[U], MatrixForm[S], MatrixForm[Vt], A == U . S . Vt}\
\>", "Input",ExpressionUUID->"1cf2f12b-6c4a-4b31-bf8d-52ad17cac46b"],

Cell["\<\
A = {{1, 0}, {1, 1}, {0, 1}};
G = Transpose[A] . A;                                    (* 1 *)
{vals, vecs} = Eigensystem[G];                           (* 2 *)
s = Sqrt[Select[vals, Positive]]; S = DiagonalMatrix[s]; (* 3 *)
r = Length[s];                                           (* 4 *)
Vt = Orthogonalize[Take[vecs, r]]; V = Transpose[Vt];    (* 5 *)
U = A . Transpose[Vt/s];                                 (* 6 *)
{MatrixForm[U], MatrixForm[S], MatrixForm[Vt], A == U . S . Vt}\
\>", "Input",ExpressionUUID->"e9cec9d4-b570-4a72-b5e8-b6bd8f33fb43"],

Cell["\<\
A = {{1, 0}, {1, 1}, {0, 1}}; b = {2, 0, 2};
PseudoInverse[A] . b\
\>", "Input",ExpressionUUID->"6fc32e73-9e29-4b5f-a057-91c8df4a2518"]
}, Closed]]
