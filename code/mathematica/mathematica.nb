D[a . x, {x}] == a
D[x . G . x, {x}] == 2 G . x // Simplify
D[(A . x) . (A . x), {x}] == 2 Transpose[A] . A . x // Simplify\
\>", "Input",ExpressionUUID->"4e241d76-cfbd-4407-b470-564516196518"],

