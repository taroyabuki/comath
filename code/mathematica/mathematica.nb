Show[Histogram[data, Automatic, \"PDF\"],
 Plot[PDF[FRatioDistribution[m - 1, n - 1]][x], {x, 0, 7}]]\
\>", "Input",ExpressionUUID->"4a6bbc64-aa8f-4f84-81d3-7a2a529f9cfe"],

