\>", "Input",ExpressionUUID->"3882c486-5fc1-4914-b637-da86052a221d"],

Cell["\<\
x1 = {1, 3, 6, 10}; y = {7, 1, 6, 14}; data = Thread[{x1, y}];
X = DesignMatrix[data, X1, X1];
yh = X . PseudoInverse[X] . y;
eh = y - yh; fh = yh - Mean[y]; g = y - Mean[y];
R2 = 1 - eh . eh/g . g; N[R2]\
\>", "Input",ExpressionUUID->"2fb1e7fb-1d46-41b5-b930-fd0bad32e7fa"],

Cell["\<\
{Mean[eh] == 0,                            (* \:7279\:5fb41 *)
 Mean[yh] == Mean[y],                      (* \:7279\:5fb42 *)
 g . g == fh . fh + eh . eh,               (* \:7279\:5fb43 *)
 R2 == fh . fh/g . g,                      (* \:7279\:5fb44 *)
 R2 == Correlation[y, yh]^2,               (* \:7279\:5fb45 *)
 0 <= R2 <= 1,                             (* \:7279\:5fb46 *)
 Correlation[y, yh] == Correlation[y, x1]} (* \:7279\:5fb47 *)\
\>", "Input",ExpressionUUID->"df5a8f6f-cbc2-4ddf-aee6-cda06f711903"],

Cell["\<\
X = {{1, 1, 2}, {1, 1, 3}, {1, 2, 5}, {1, 3, 7}};
{n, p} = Dimensions[X];
beta = Table[Subscript[\[Beta], i - 1], {i, p}];
epsilon = Table[Subscript[\[Epsilon], i], {i, n}];
Y = X . beta + epsilon;
betah = PseudoInverse[X] . Y // Simplify\
\>", "Input",ExpressionUUID->"dc320c9f-ed30-4488-9014-cd8be41cf9b9"],

Cell["\<\
Clear[sigma];
udist = UniformDistribution[{-Sqrt[3] sigma, Sqrt[3] sigma}];
udists = Table[Distributed[v, udist], {v, epsilon}];
Expectation[betah, udists]\
\>", "Input",ExpressionUUID->"26d5b5b9-4e39-4a96-9822-21a83aff1f25"],

Cell["\<\
Z = {{1, 0, 0}, {0, 1, 0}, {0, 0, 1}, {0, 0, 0}};
Cz = Inverse[Transpose[Z] . X] . Transpose[Z];
b = Cz . Y;
Expectation[b, udists]\
\>", "Input",ExpressionUUID->"5cbb5ad5-76bf-4786-ba68-1481c7b17930"],

Cell["\<\
dist1 = TransformedDistribution[b, udists];
dist2 = TransformedDistribution[betah, udists];
Eigenvalues[Covariance[dist1] - Covariance[dist2]]\
\>", "Input",ExpressionUUID->"4e7c2cb2-76a5-4570-b6fe-f472d5ca309e"],

Cell["\<\
Variance[dist1]
Variance[dist2]\
\>", "Input",ExpressionUUID->"5a63d5f2-3a27-4793-b4f9-a0d42d4d52c6"],

Cell["\<\
ndist = NormalDistribution[0, sigma];
ndists = Table[Distributed[v, ndist], {v, epsilon}];
TransformedDistribution[betah, ndists] ==
 MultinormalDistribution[beta, sigma^2 Inverse[Transpose[X] . X]]\
\>", "Input",ExpressionUUID->"fb03463a-99db-455f-ade1-a02419365978"],

Cell["\<\
