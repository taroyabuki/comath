Cell["\<\
Clear[a, b, p, q, r, s, t, u];
L = Total[(y - (a x + b))^2];
M = p (a - q)^2 + r (b - (s a + t))^2 + u;
tmp = SolveAlways[L == M, {a, b}][[1]];
M /. tmp\
\>", "Input",ExpressionUUID->"38377b2b-e0a0-4090-9ca0-4e7f4985f490"],

