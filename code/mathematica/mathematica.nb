\>", "Input",ExpressionUUID->"c90f6a7c-3359-46db-a671-5b379a556f82"],

Cell["\<\
A = {{1, 0, 1}, {1, 1, 0}, {0, 1, -1}};
tmp = ResourceFunction[\"ColumnSpace\"][A];
basis = Orthogonalize[tmp[\"Basis\"]]\
\>", "Input",ExpressionUUID->"672bba71-0cd0-453f-bd0c-9d4148f27886"],

Cell["\<\
Q = Transpose[basis];
Transpose[Q] . Q\
\>", "Input",ExpressionUUID->"253003be-c9f2-40ab-9c91-e708e877218c"],

Cell["\<\
A = {{1, 0, 1}, {1, 1, 0}, {0, 1, -1}};
{Qt, R} = QRDecomposition[A]; Q = Transpose[Qt];
{MatrixForm[Q], MatrixForm[R], A == Q . R}\
\>", "Input",ExpressionUUID->"bf5a910b-c779-4d22-af43-c0176fede532"],

Cell["\<\
A = {{1, 0}, {1, 1}, {0, 1}};
NullSpace[Transpose[A]]\
\>", "Input",ExpressionUUID->"0b4fee09-13a5-473c-82c2-75bfb71d4244"],

Cell["\<\
Clear[a, b, c, d, f, s, t, u, x, y]; A = {{a, b}, {c, d}};
f[x_] := A . x
R = ParametricRegion[{x, y}, {{x, s, s + u}, {y, t, t + u}}];
Rp = TransformedRegion[R, f];
{RegionMeasure[Rp], Abs[Det[A]] u^2}\
\>", "Input",ExpressionUUID->"5f5161e5-d002-448f-8274-c264a51ab335"]
}, Closed]],

Cell[CellGroupData[{

Cell["19 \:56fa\:6709\:5024\:3068\:56fa\:6709\:30d9\:30af\:30c8\:30eb", \
"Chapter",ExpressionUUID->"9ff373e5-7946-4a98-8784-4b40244484f2"],

Cell["\<\
A = {{2, 1}, {4, -1}};
eigs = Eigensystem[A]\
\>", "Input",ExpressionUUID->"70e05476-16b3-498b-bda1-36db8d41cf3a"],

Cell["Solve[Det[x IdentityMatrix[2] - A] == 0, x]", "Input",ExpressionUUID->"9d108370-32e5-453e-950d-b715bbd0d630"],

Cell["\<\
Clear[x, y]; Reduce[(3 IdentityMatrix[2] - A) . {x, y} == {0, 0}, {x, y}]\
\>", "Input",ExpressionUUID->"6921ae07-4d64-40de-8aff-2cfd750244cb"],

Cell["\<\
S = {{2, 2, -2}, {2, 5, -4}, {-2, -4, 5}};
{Q, L, V} = SingularValueDecomposition[S];
{MatrixForm[Q], MatrixForm[L],
 S == Q . L . Transpose[Q], S == V . L . Transpose[V]}\
\>", "Input",ExpressionUUID->"481eba9e-16d1-4a59-b91e-0cffa468044a"],

Cell["\<\
S = {{2, 2, -2}, {2, 5, -4}, {-2, -4, 5}};
{vals, vecs} = Eigensystem[S];      (* \:56fa\:6709\:5024\:30fb\:56fa\:6709\
\:30d9\:30af\:30c8\:30eb *)
Q = Transpose[Orthogonalize[vecs]]; (* \:6b63\:898f\:76f4\:4ea4\:306a\:56fa\
\:6709\:30d9\:30af\:30c8\:30eb *)
L = DiagonalMatrix[vals];           (* \:5bfe\:89d2\:884c\:5217 *)
{MatrixForm[Q], MatrixForm[L], S == Q . L . Transpose[Q]}\
\>", "Input",ExpressionUUID->"91f55d4b-9c24-4a62-9fab-a0d4bad0570e"],

Cell["PositiveSemidefiniteMatrixQ[{{4, 2}, {2, 1}}]", "Input",ExpressionUUID->"2535a5d5-d9e6-4e83-a4cc-ffaf3009a726"],

Cell["\<\
A = {{4, 2}, {2, 1}};
AllTrue[Eigenvalues[A], NonNegative]\
\>", "Input",ExpressionUUID->"d7044658-89e2-4420-acbe-486475118382"],

Cell["\<\
A = {{46, 46}, {46, 86}};
{v1, v2} = Eigenvectors[N[A]][[1]]\
\>", "Input",ExpressionUUID->"2e8949dd-17d7-492a-bd62-e99fa546466a"],

Cell["\<\
x1 = {1, 3, 6, 10}; y = {7, 1, 6, 14};
X = Transpose[{x1 - Mean[x1], y - Mean[y]}];
A = Transpose[X] . X\
\>", "Input",ExpressionUUID->"68e55c01-1b58-40e3-9f25-4143bd158ff2"],

Cell["Reduce[v1 (yp - Mean[y]) == v2 (xp - Mean[x1]), yp] // N", "Input",ExpressionUUID->"dd990ffc-3f2a-47b0-8ecd-304263d5abbe"],

Cell["\<\
