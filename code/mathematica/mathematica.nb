eigs = Eigensystem[A]\
\>", "Input",ExpressionUUID->"bf7e3e86-6a98-483f-a69f-304fd8ab8019"],

Cell["Solve[Det[x IdentityMatrix[2] - A] == 0, x]", "Input",ExpressionUUID->"6e5b944f-fc73-43ff-8ce5-b81c7d1023f7"],

Cell["\<\
Clear[x, y]; Reduce[(3 IdentityMatrix[2] - A) . {x, y} == {0, 0}, {x, y}]\
\>", "Input",ExpressionUUID->"e2391b0e-018c-4038-879b-93383c577a5c"],

Cell["\<\
S = {{2, 2, -2}, {2, 5, -4}, {-2, -4, 5}};
{Q, L, V} = SingularValueDecomposition[S];
{MatrixForm[Q], MatrixForm[L],
 S == Q . L . Transpose[Q], S == V . L . Transpose[V]}\
\>", "Input",ExpressionUUID->"99c0ec99-21c3-4ede-99b3-dd687f9b897c"],

Cell["\<\
S = {{2, 2, -2}, {2, 5, -4}, {-2, -4, 5}};
{vals, vecs} = Eigensystem[S];      (* 1 *)
Q = Transpose[Orthogonalize[vecs]]; (* 2, 3 *)
L = DiagonalMatrix[vals];           (* 4 *)
{MatrixForm[Q], MatrixForm[L], S == Q . L . Transpose[Q]}\
\>", "Input",ExpressionUUID->"3b9cd47f-3d9e-4248-b047-d30020626127"],

Cell["PositiveSemidefiniteMatrixQ[{{4, 2}, {2, 1}}]", "Input",ExpressionUUID->"17f7ebb6-035c-4b90-87b1-114618618d84"],

Cell["\<\
A = {{4, 2}, {2, 1}};
AllTrue[Eigenvalues[A], NonNegative]\
\>", "Input",ExpressionUUID->"3f8d0bde-66fa-4211-aa50-6ef0027caed5"],

Cell["\<\
A = {{46, 46}, {46, 86}};
{v1, v2} = Eigenvectors[N[A], 1][[1]]\
\>", "Input",ExpressionUUID->"01993d45-f008-48d5-a814-503a983d1130"],

Cell["\<\
x1 = {1, 3, 6, 10}; y = {7, 1, 6, 14};
X = Transpose[{x1 - Mean[x1], y - Mean[y]}];
A = Transpose[X] . X\
\>", "Input",ExpressionUUID->"8d66728e-5099-41f5-80f3-a596b2084763"],

Cell["Reduce[v1 (yp - Mean[y]) == v2 (xp - Mean[x1]), yp] // N", "Input",ExpressionUUID->"b8b25044-7aef-47ce-a2b4-d3ed9df5b18f"],

Cell["\<\
