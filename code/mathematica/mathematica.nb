V[[All, 1]] // N\
\>", "Input",ExpressionUUID->"365cfe01-cc5f-4d20-8059-7f9a00e8b3e3"]
}, Closed]],

Cell[CellGroupData[{

Cell["20 \:7279\:7570\:5024\:5206\:89e3\:3068\:7591\:4f3c\:9006\:884c\:5217", \
"Chapter",ExpressionUUID->"b8928332-b9fd-438a-b3e4-a1ebbdc4f5f8"],

Cell["\<\
A = {{1, 0}, {1, 1}, {0, 1}};
{U, S, V} = SingularValueDecomposition[A]; Vt = Transpose[V];
{MatrixForm[U], MatrixForm[S], MatrixForm[Vt], A == U . S . Vt}\
\>", "Input",ExpressionUUID->"5187c450-252a-464a-aa88-52ef4751b88e"],

Cell["\<\
A = {{1, 0}, {1, 1}, {0, 1}};
G = Transpose[A] . A;                                    (* 1 *)
{vals, vecs} = Eigensystem[G];                           (* 2 *)
s = Sqrt[Select[vals, Positive]]; S = DiagonalMatrix[s]; (* 3 *)
r = Length[s];                                           (* 4 *)
Vt = Orthogonalize[Take[vecs, r]]; V = Transpose[Vt];    (* 5 *)
U = A . Transpose[Vt/s];                                 (* 6 *)
{MatrixForm[U], MatrixForm[S], MatrixForm[Vt], A == U . S . Vt}\
\>", "Input",ExpressionUUID->"8b7374aa-a12b-4c76-8c11-b816765c262b"],

Cell["\<\
A = {{1, 0}, {1, 1}, {0, 1}}; b = {2, 0, 2};
PseudoInverse[A] . b\
\>", "Input",ExpressionUUID->"5459771d-491e-4150-ba85-7ed36c24ff22"]
}, Closed]]
