F = Variance[x]/Variance[y]/r; f = F /. r -> 1;
c = CDF[dist][f];
{f, 2 Min[c, 1 - c]} // N\
\>", "Input",ExpressionUUID->"b4ab20a3-5704-4b01-99c4-dd6e734d7888"],

Cell["\<\
