Cell["\<\
data = {{1, 2, 3}, {1, 3, 6}, {2, 5, 3}, {3, 7, 6}};
X = DesignMatrix[data, {X1, X2}, {X1, X2}];
y = data[[All, -1]];
Inverse[Transpose[X] . X] . Transpose[X] . y\
\>", "Input",ExpressionUUID->"cfa90322-9dc9-40c1-9c24-1b10803fe016"],

Cell["PseudoInverse[X] . y", "Input",ExpressionUUID->"4372e5da-f3fa-472a-9dca-33bb4b596cfe"],

Cell["\<\
b = {b0, b1, b2};
L = (y - X . b) . (y - X . b);
Reduce[{D[L, {b}] == {0, 0, 0}}]\
\>", "Input",ExpressionUUID->"01b4b928-4df2-42b0-b559-431fb5aa75fe"],

Cell["\<\
D[L, {b}] == -2 Transpose[X] . y + 2 Transpose[X] . X . b // Simplify\
\>", "Input",ExpressionUUID->"df42a8f3-7c52-40d5-9ef8-9fba6688b4ea"],

Cell["\<\
