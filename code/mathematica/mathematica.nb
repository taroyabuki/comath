A = Transpose[X] . X\
\>", "Input",ExpressionUUID->"c98966c3-d222-490e-9a02-ed6125b8ac79"],

Cell["Reduce[v1 (yp - Mean[y]) == v2 (xp - Mean[x1]), yp] // N", "Input",ExpressionUUID->"e84f2822-76ce-494d-8eb3-49c72e4bb252"],

Cell["\<\
