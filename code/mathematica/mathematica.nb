Cell["18 \:30d9\:30af\:30c8\:30eb\:7a7a\:9593", "Chapter",ExpressionUUID->"6589d70c-1d7c-4fe3-9f1a-1979aad7f2c8"],

Cell["\<\
a1 = {3, 1}; a2 = {2, 2};
ResourceFunction[\"LinearlyIndependent\"][{a1, a2}]\
\>", "Input",ExpressionUUID->"0f64ef30-75e2-466f-8392-5841289468fd"],

Cell["Reduce[c1 a1 + c2 a2 == {0, 0}]", "Input",ExpressionUUID->"54f7e187-331e-4263-9f96-2007e03cafe5"],

Cell["\<\
A = {{1, 0, 1}, {1, 1, 0}, {0, 1, -1}};
ResourceFunction[\"ColumnSpace\"][A][\"Basis\"]\
\>", "Input",ExpressionUUID->"2f226961-41fb-4818-b524-cd6e781c26f9"],

Cell["\<\
A = {{1, 0, 1}, {1, 1, 0}, {0, 1, -1}};
tmp = ResourceFunction[\"ColumnSpace\"][A];
basis = Orthogonalize[tmp[\"Basis\"]]\
\>", "Input",ExpressionUUID->"341941f5-1ad4-4686-8976-a768ca54b3e5"],

Cell["\<\
Q = Transpose[basis];
Transpose[Q] . Q\
\>", "Input",ExpressionUUID->"833f32cc-f670-48f6-b981-6cd4d6cf08ac"],

Cell["\<\
A = {{1, 0, 1}, {1, 1, 0}, {0, 1, -1}};
{Qt, R} = QRDecomposition[A]; Q = Transpose[Qt];
{MatrixForm[Q], MatrixForm[R], A == Q . R}\
\>", "Input",ExpressionUUID->"b6ce6056-221b-4885-831f-7705d547c22e"],

Cell["\<\
A = {{1, 0}, {1, 1}, {0, 1}};
NullSpace[Transpose[A]]\
\>", "Input",ExpressionUUID->"9b054bdd-d9f8-4cc7-836e-cf8265505986"],

Cell["\<\
Clear[a, b, c, d, f, s, t, u, x, y];
A = {{a, b}, {c, d}};
f[x_] := A . x
R = ParametricRegion[{x, y}, {{x, s, s + u}, {y, t, t + u}}];
Rp = TransformedRegion[R, f];
{RegionMeasure[Rp], Abs[Det[A]] u^2}\
\>", "Input",ExpressionUUID->"ee3ddfa8-2600-4659-bfc2-f315ebe5a7cf"]
}, Closed]],

Cell[CellGroupData[{

Cell["19 \:56fa\:6709\:5024\:3068\:56fa\:6709\:30d9\:30af\:30c8\:30eb", \
"Chapter",ExpressionUUID->"3f737189-ea0a-4aa3-afdb-376ed04bd9e4"],

Cell["\<\
A = {{2, 1}, {4, -1}};
eigs = Eigensystem[A]\
\>", "Input",ExpressionUUID->"6e91fc0a-926e-4773-aea7-ce598baf1f13"],

Cell["Solve[Det[x IdentityMatrix[2] - A] == 0, x]", "Input",ExpressionUUID->"52a6bfc3-28d4-4956-b4e9-65487e507722"],

Cell["\<\
Clear[x, y]; Reduce[(3 IdentityMatrix[2] - A) . {x, y} == {0, 0}, {x, y}]\
\>", "Input",ExpressionUUID->"a0458643-4958-465c-ab7c-1c8153a57cbd"],

Cell["\<\
S = {{2, 2, -2}, {2, 5, -4}, {-2, -4, 5}};
{Q, L, V} = SingularValueDecomposition[S];
{MatrixForm[Q], MatrixForm[L],
 S == Q . L . Transpose[Q], S == V . L . Transpose[V]}\
\>", "Input",ExpressionUUID->"edc69377-49ec-4341-b774-edac765c0d63"],

Cell["\<\
S = {{2, 2, -2}, {2, 5, -4}, {-2, -4, 5}};
{vals, vecs} = Eigensystem[S];      (* 1 *)
Q = Transpose[Orthogonalize[vecs]]; (* 2, 3 *)
L = DiagonalMatrix[vals];           (* 4 *)
{MatrixForm[Q], MatrixForm[L], S == Q . L . Transpose[Q]}\
\>", "Input",ExpressionUUID->"3547751e-203e-4c5a-920c-a5fad17cb975"],

Cell["PositiveSemidefiniteMatrixQ[{{4, 2}, {2, 1}}]", "Input",ExpressionUUID->"80dd8f2e-2992-4608-9f5c-79e124db987b"],

Cell["\<\
A = {{4, 2}, {2, 1}};
AllTrue[Eigenvalues[A], NonNegative]\
\>", "Input",ExpressionUUID->"144554b6-b148-4665-8f3e-9400d3bd9262"],

Cell["\<\
A = {{46, 46}, {46, 86}};
{v1, v2} = Eigenvectors[N[A], 1][[1]]\
\>", "Input",ExpressionUUID->"eb29081b-781d-4f2c-bb0c-f6b903e6d27e"],

Cell["\<\
x1 = {1, 3, 6, 10}; y = {7, 1, 6, 14};
X = Transpose[{x1 - Mean[x1], y - Mean[y]}];
A = Transpose[X] . X\
\>", "Input",ExpressionUUID->"c692831c-60a1-4758-8aa0-99fb7c0f215f"],

Cell["Reduce[v1 (yp - Mean[y]) == v2 (xp - Mean[x1]), yp] // N", "Input",ExpressionUUID->"64c5aeb3-293c-4529-bc25-06bf606886cc"],

Cell["\<\
