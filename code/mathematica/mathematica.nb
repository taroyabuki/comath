eigs = Eigensystem[A]\
\>", "Input",ExpressionUUID->"b00d4f25-3628-4b08-a4e7-3b114ceb53af"],

Cell["Solve[Det[x IdentityMatrix[2] - A] == 0, x]", "Input",ExpressionUUID->"77adf444-e979-4d94-a489-a1b26a80e439"],

Cell["\<\
Clear[x, y]; Reduce[(3 IdentityMatrix[2] - A) . {x, y} == {0, 0}, {x, y}]\
\>", "Input",ExpressionUUID->"42d0cec5-3490-45ac-9335-932b7fdba001"],

Cell["\<\
S = {{2, 2, -2}, {2, 5, -4}, {-2, -4, 5}};
{Q, L, V} = SingularValueDecomposition[S];
{MatrixForm[Q], MatrixForm[L], MatrixForm[Q . L . Transpose[Q]]}\
\>", "Input",ExpressionUUID->"02b954e7-8ec6-4528-b61f-fb08f080e76e"],

Cell["\<\
S = {{2, 2, -2}, {2, 5, -4}, {-2, -4, 5}};
{vals, vecs} = Eigensystem[S];      (* \:56fa\:6709\:5024\:30fb\:56fa\:6709\
\:30d9\:30af\:30c8\:30eb *)
Q = Transpose[Orthogonalize[vecs]]; (* \:6b63\:898f\:76f4\:4ea4\:306a\:56fa\
\:6709\:30d9\:30af\:30c8\:30eb *)
L = DiagonalMatrix[vals];           (* \:5bfe\:89d2\:884c\:5217 *)
{MatrixForm[Q], MatrixForm[L], MatrixForm[Q . L . Transpose[Q]]}\
\>", "Input",ExpressionUUID->"b1843199-f5cc-4774-8070-f9bc46fa1dcb"],

Cell["PositiveSemidefiniteMatrixQ[{{4, 2}, {2, 1}}]", "Input",ExpressionUUID->"003f34ee-38e9-436c-b87a-f628e6cdeb3a"],

Cell["\<\
A = {{4, 2}, {2, 1}};
AllTrue[Eigenvalues[A], NonNegative]\
\>", "Input",ExpressionUUID->"975809c9-505d-4727-b008-3f1fd1d13848"],

Cell["\<\
A = {{46, 46}, {46, 86}};
{v1, v2} = Eigenvectors[N[A]][[1]]\
\>", "Input",ExpressionUUID->"8ddfd151-85e6-4793-9560-7bf031865560"],

Cell["\<\
x1 = {1, 3, 6, 10}; y = {7, 1, 6, 14};
X = Transpose[{x1 - Mean[x1], y - Mean[y]}];
A = Transpose[X] . X\
\>", "Input",ExpressionUUID->"b69062cc-2ff0-4859-b85d-e0512c270d78"],

Cell["Reduce[v1 (yp - Mean[y]) == v2 (xp - Mean[x1]), yp] // N", "Input",ExpressionUUID->"81e7c53c-56d1-450a-a278-ad75d1dea2b3"],

Cell["\<\
