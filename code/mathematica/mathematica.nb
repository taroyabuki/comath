Cell["\<\
x = {25, 24, 25, 26}; y = {23, 18, 22, 28, 17, 25, 19, 16};
TTest[{x, y}, 0, AlternativeHypothesis -> \"Greater\",
 VerifyTestAssumptions -> \"EqualVariance\" -> False]\
\>", "Input",ExpressionUUID->"a5f1dc45-c7cc-45ce-9ada-cf4a5fcb943b"],

Cell["\<\
alpha = 5/100;
m = Length[x]; n = Length[y]; sx2 = Variance[x]; sy2 = Variance[y];
s2 = ((m - 1) sx2 + (n - 1) sy2)/(m + n - 2);
T = (Mean[x] - Mean[y] - d)/Sqrt[s2 (1/m + 1/n)];
t := T /. d -> 0                  (* t\:5024 *)
df = m + n - 2;                   (* \:81ea\:7531\:5ea6 *)
dist := StudentTDistribution[df];
P := 1 - CDF[dist][t];            (* P\:5024 *)
a := InverseCDF[dist, 1 - alpha]; (* \:63a1\:629e\:57df\:306e\:4e0a\:9650 *)
interval := Reduce[T <= a, d]     (* \:4fe1\:983c\:533a\:9593 *)
{t, P, a, interval} // N\
\>", "Input",ExpressionUUID->"89f7e5a6-f0f0-44aa-9cc1-33f4e51e61f9"],

Cell["\<\
T = (Mean[x] - Mean[y] - d)/Sqrt[sx2/m + sy2/n];
df = (sx2/m + sy2/n)^2/((sx2/m)^2/(m - 1) + (sy2/n)^2/(n - 1)) // N;
{t, P, a, interval} // N\
\>", "Input",ExpressionUUID->"42a9e10a-ad99-4f70-b5d0-17735b0d4038"],

