Table[2 Min[CDF[tdist][v], 1 - CDF[tdist][v]], {v, t}] // N\
\>", "Input",ExpressionUUID->"2b8c1ead-7657-4478-9e1f-0b3a01b1fc9f"],

Cell["\<\
