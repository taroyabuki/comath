NullSpace[Transpose[A]]\
\>", "Input",ExpressionUUID->"d796f72b-9b97-4a89-b1d0-a695b4e652b7"],

Cell["\<\
Clear[a, b, c, d, f, s, t, u, x, y]; A = {{a, b}, {c, d}};
f[x_] := A . x
R = ParametricRegion[{x, y}, {{x, s, s + u}, {y, t, t + u}}];
Rp = TransformedRegion[R, f];
{RegionMeasure[Rp], Abs[Det[A]] u^2}\
\>", "Input",ExpressionUUID->"ed281b79-e057-4b9e-b37a-f7602c2a714c"]
}, Closed]],

Cell[CellGroupData[{

Cell["19 \:56fa\:6709\:5024\:3068\:56fa\:6709\:30d9\:30af\:30c8\:30eb", \
"Chapter",ExpressionUUID->"8bf5d599-f4a0-4a83-aced-1fc00fad0484"],

Cell["\<\
