V[[All, 1]] // N\
\>", "Input",ExpressionUUID->"03dd87e7-1aee-480f-8a37-cfbbb7803f08"]
}, Closed]],

Cell[CellGroupData[{

Cell["20 \:7279\:7570\:5024\:5206\:89e3\:3068\:7591\:4f3c\:9006\:884c\:5217", \
"Chapter",ExpressionUUID->"b798727e-5a79-4421-bd49-e91de7dcb789"],

Cell["\<\
A = {{1, 0}, {1, 1}, {0, 1}};
{U, S, V} = SingularValueDecomposition[A];
{MatrixForm[U], MatrixForm[S], MatrixForm[Transpose[V]],
 MatrixForm[U . S . Transpose[V]]}\
\>", "Input",ExpressionUUID->"b31ca26e-fa39-4edc-aee9-dbccb2be80e0"],

Cell["\<\
A = {{1, 0}, {1, 1}, {0, 1}};
G = Transpose[A] . A;                                    (* 1 *)
{vals, vecs} = Eigensystem[G];                           (* 2 *)
s = Sqrt[Select[vals, Positive]]; S = DiagonalMatrix[s]; (* 3 *)
r = Length[s];                                           (* 4 *)
Vt = Orthogonalize[Take[vecs, r]]; V = Transpose[Vt];    (* 5 *)
U = A . V . Inverse[S];                                  (* 6 *)
{MatrixForm[U], MatrixForm[S], MatrixForm[Vt], MatrixForm[U . S . Vt]}\
\>", "Input",ExpressionUUID->"0a3ee59d-dd72-4fda-ba8a-70ccf61aacc0"],

Cell["\<\
A = {{1, 0}, {1, 1}, {0, 1}}; b = {2, 0, 2};
PseudoInverse[A] . b\
\>", "Input",ExpressionUUID->"a3aa0cbf-8c67-4327-97de-0117fb57f585"]
}, Closed]]
