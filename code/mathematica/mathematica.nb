\>", "Input",ExpressionUUID->"407ecbb9-9f8b-4a18-95e7-9c1b5d2b7878"],

Cell["Reduce[c1 a1 + c2 a2 == {0, 0}]", "Input",ExpressionUUID->"615c6125-19f7-44a0-b2c2-5b00f4c4411a"],

Cell["\<\
A = {{1, 0, 1}, {1, 1, 0}, {0, 1, -1}};
ResourceFunction[\"ColumnSpace\"][A][\"Basis\"]\
\>", "Input",ExpressionUUID->"bc80af90-cd7c-4f2c-a374-a2c5f3e0df1d"],

Cell["\<\
A = {{1, 0, 1}, {1, 1, 0}, {0, 1, -1}};
tmp = ResourceFunction[\"ColumnSpace\"][A];
basis = Orthogonalize[tmp[\"Basis\"]]\
\>", "Input",ExpressionUUID->"3607abd1-fdcb-4d42-b808-7241a51cb8b1"],

Cell["\<\
Q = Transpose[basis];
Transpose[Q] . Q\
\>", "Input",ExpressionUUID->"8ff6af91-14cb-404b-9eaa-ebfd7a2cac73"],

Cell["\<\
A = {{1, 0, 1}, {1, 1, 0}, {0, 1, -1}};
{Qt, R} = QRDecomposition[A]; Q = Transpose[Qt];
{MatrixForm[Q], MatrixForm[R], MatrixForm[Q . R]}\
\>", "Input",ExpressionUUID->"9622a3aa-1c23-4457-9274-e2878e7bd8aa"],

Cell["\<\
