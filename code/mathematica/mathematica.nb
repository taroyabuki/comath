A = Transpose[X] . X\
\>", "Input",ExpressionUUID->"ad92e64a-afc8-4454-8f66-5cb905e6f169"],

Cell["Reduce[v1 (yp - Mean[y]) == v2 (xp - Mean[x1]), yp] // N", "Input",ExpressionUUID->"9da79cfe-0d1f-44f8-9923-fa840c5e24f4"],

Cell["\<\
