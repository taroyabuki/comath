Cell[CellGroupData[{

Cell["18 \:30d9\:30af\:30c8\:30eb\:7a7a\:9593", "Chapter",ExpressionUUID->"5b8402ac-04e0-46b7-be5f-76efc6370c35"],

Cell["\<\
a1 = {3, 1}; a2 = {2, 2};
ResourceFunction[\"LinearlyIndependent\"][{a1, a2}]\
\>", "Input",ExpressionUUID->"7176598e-ee6c-4834-a7a9-3a6e3e2db6ad"],

Cell["Reduce[c1 a1 + c2 a2 == {0, 0}]", "Input",ExpressionUUID->"33b308e9-a859-4ead-bf71-025cb12d6ab8"],

Cell["\<\
A = {{1, 0, 1}, {1, 1, 0}, {0, 1, -1}};
ResourceFunction[\"ColumnSpace\"][A][\"Basis\"]\
\>", "Input",ExpressionUUID->"c4f815ae-7f16-4073-bf16-8e374ab236bb"],

Cell["\<\
A = {{1, 0, 1}, {1, 1, 0}, {0, 1, -1}};
tmp = ResourceFunction[\"ColumnSpace\"][A];
basis = Orthogonalize[tmp[\"Basis\"]]\
\>", "Input",ExpressionUUID->"a49bb325-29e5-4a7c-9449-31e4aaaaf04f"],

Cell["\<\
Q = Transpose[basis];
Transpose[Q] . Q\
\>", "Input",ExpressionUUID->"c7a5a4cd-9450-418c-90f6-26bcf29d7a6d"],

Cell["\<\
A = {{1, 0, 1}, {1, 1, 0}, {0, 1, -1}};
{Qt, R} = QRDecomposition[A]; Q = Transpose[Qt];
{MatrixForm[Q], MatrixForm[R], A == Q . R}\
\>", "Input",ExpressionUUID->"3d32cab1-6ad1-4314-bd0e-b245312132e6"],

Cell["\<\
A = {{1, 0}, {1, 1}, {0, 1}};
NullSpace[Transpose[A]]\
\>", "Input",ExpressionUUID->"e9caa14c-98b5-4135-a46f-4037f3a99582"],

Cell["\<\
Clear[a, b, c, d, f, s, t, u, x, y];
A = {{a, b}, {c, d}};
f[x_] := A . x
R = ParametricRegion[{x, y}, {{x, s, s + u}, {y, t, t + u}}];
Rp = TransformedRegion[R, f];
{RegionMeasure[Rp], Abs[Det[A]] u^2}\
\>", "Input",ExpressionUUID->"b63d6867-3831-4a69-91a0-7e42baf89ec3"]
}, Closed]],

Cell[CellGroupData[{

Cell["19 \:56fa\:6709\:5024\:3068\:56fa\:6709\:30d9\:30af\:30c8\:30eb", \
"Chapter",ExpressionUUID->"469a61f3-d8ed-431d-9800-de80b81fdd96"],

Cell["\<\
A = {{2, 1}, {4, -1}};
eigs = Eigensystem[A]\
\>", "Input",ExpressionUUID->"9a2de724-cc3f-4bf9-a98c-ceff32a4ce13"],

Cell["Solve[Det[x IdentityMatrix[2] - A] == 0, x]", "Input",ExpressionUUID->"4791fb16-1795-49c2-8b9d-45b474ed9aa5"],

Cell["\<\
Clear[x, y]; Reduce[(3 IdentityMatrix[2] - A) . {x, y} == {0, 0}, {x, y}]\
\>", "Input",ExpressionUUID->"6169fe79-779e-4f90-b7a8-79f0c0709ef3"],

Cell["\<\
S = {{2, 2, -2}, {2, 5, -4}, {-2, -4, 5}};
{Q, L, V} = SingularValueDecomposition[S];
{MatrixForm[Q], MatrixForm[L],
 S == Q . L . Transpose[Q], S == V . L . Transpose[V]}\
\>", "Input",ExpressionUUID->"6405b7b1-d5ad-41fe-acbe-cebf0c88bfb0"],

Cell["\<\
S = {{2, 2, -2}, {2, 5, -4}, {-2, -4, 5}};
{vals, vecs} = Eigensystem[S];      (* 1 *)
Q = Transpose[Orthogonalize[vecs]]; (* 2, 3 *)
L = DiagonalMatrix[vals];           (* 4 *)
{MatrixForm[Q], MatrixForm[L], S == Q . L . Transpose[Q]}\
\>", "Input",ExpressionUUID->"0562552e-8485-4b8f-8d5b-137cdb29e988"],

Cell["PositiveSemidefiniteMatrixQ[{{4, 2}, {2, 1}}]", "Input",ExpressionUUID->"adf23be8-343c-4bfa-ae81-582479fb94e2"],

Cell["\<\
A = {{4, 2}, {2, 1}};
AllTrue[Eigenvalues[A], NonNegative]\
\>", "Input",ExpressionUUID->"a8728f49-ca57-43cb-a1f2-c9f27adda1b6"],

Cell["\<\
A = {{46, 46}, {46, 86}};
{v1, v2} = Eigenvectors[N[A], 1][[1]]\
\>", "Input",ExpressionUUID->"27f7b405-9ec9-482d-bf1a-9469e2b028e5"],

Cell["\<\
x1 = {1, 3, 6, 10}; y = {7, 1, 6, 14};
X = Transpose[{x1 - Mean[x1], y - Mean[y]}];
A = Transpose[X] . X\
\>", "Input",ExpressionUUID->"db9f8f8c-1932-4b1c-ac0e-44b501ee9ee2"],

Cell["Reduce[v1 (yp - Mean[y]) == v2 (xp - Mean[x1]), yp] // N", "Input",ExpressionUUID->"1ef73e08-5fef-494c-99ca-2d036064b9ab"],

Cell["\<\
{U, S, V} = SingularValueDecomposition[X];
V[[All, 1]] // N\
\>", "Input",ExpressionUUID->"784a2d41-08c3-4e36-bd8a-2035a474cbdf"]
}, Closed]],

Cell[CellGroupData[{

Cell["20 \:7279\:7570\:5024\:5206\:89e3\:3068\:7591\:4f3c\:9006\:884c\:5217", \
"Chapter",ExpressionUUID->"797c6dc0-1c3f-4b22-8b4f-661c76f03c89"],

Cell["\<\
A = {{1, 0}, {1, 1}, {0, 1}};
{U, S, V} = SingularValueDecomposition[A]; Vt = Transpose[V];
{MatrixForm[U], MatrixForm[S], MatrixForm[Vt], A == U . S . Vt}\
\>", "Input",ExpressionUUID->"92e1420d-3754-4cbb-96fb-05735b8db8a2"],

Cell["\<\
A = {{1, 0}, {1, 1}, {0, 1}};
G = Transpose[A] . A;                                    (* 1 *)
{vals, vecs} = Eigensystem[G];                           (* 2 *)
s = Sqrt[Select[vals, Positive]]; S = DiagonalMatrix[s]; (* 3 *)
r = Length[s];                                           (* 4 *)
Vt = Orthogonalize[Take[vecs, r]]; V = Transpose[Vt];    (* 5 *)
U = A . Transpose[Vt/s];                                 (* 6 *)
{MatrixForm[U], MatrixForm[S], MatrixForm[Vt], A == U . S . Vt}\
\>", "Input",ExpressionUUID->"807f5b2b-eda5-4092-a0a0-a5236fc72e77"],

Cell["\<\
A = {{1, 0}, {1, 1}, {0, 1}}; b = {2, 0, 2};
PseudoInverse[A] . b\
\>", "Input",ExpressionUUID->"6fdcfaea-8081-4d97-9ed3-913275bd9ee8"]
}, Closed]]
