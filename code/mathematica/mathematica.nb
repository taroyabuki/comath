\>", "Input",ExpressionUUID->"5b88da1a-893e-4308-be8a-f2b9bb7f462a"],

Cell["\<\
m = Length[x]; n = Length[y]; dist = FRatioDistribution[m - 1, n - 1];
F = Variance[x]/Variance[y]/r; f = F /. r -> 1;
c = CDF[dist][f];
{f, 2 Min[c, 1 - c]} // N\
\>", "Input",ExpressionUUID->"319653c2-aa78-48b8-97e6-cc95820c40a6"],

Cell["\<\
