\>", "Input",ExpressionUUID->"ea05f97a-0e16-4efb-8924-f9880db469a2"],

Cell["\<\
A = {{3, 2}, {1, 2}}; b = {8, 4};
Inverse[A] . b\
\>", "Input",ExpressionUUID->"6bf4f787-eb2d-4757-b3ba-c131650b92ac"],

Cell["RowReduce[{{4, 2, 8}, {2, 1, 4}}]", "Input",ExpressionUUID->"dcbb6319-9539-4773-a082-5eab1be97e67"]
}, Closed]],

Cell[CellGroupData[{

Cell["18 \:30d9\:30af\:30c8\:30eb\:7a7a\:9593", "Chapter",ExpressionUUID->"7b3cea97-b9f0-4ae7-8501-2223c4c6edaa"],

Cell["\<\
a1 = {3, 1}; a2 = {2, 2};
ResourceFunction[\"LinearlyIndependent\"][{a1, a2}]\
\>", "Input",ExpressionUUID->"99fb1a8c-903c-4508-89c2-61eb93c85807"],

Cell["Reduce[c1 a1 + c2 a2 == {0, 0}]", "Input",ExpressionUUID->"716f66fe-818a-41ed-82e9-a9d311914152"],

Cell["\<\
A = {{1, 0, 1}, {1, 1, 0}, {0, 1, -1}};
ResourceFunction[\"ColumnSpace\"][A][\"Basis\"]\
\>", "Input",ExpressionUUID->"70fe4948-df6c-405e-b647-2fcfcb493e90"],

Cell["\<\
A = {{1, 0, 1}, {1, 1, 0}, {0, 1, -1}};
tmp = ResourceFunction[\"ColumnSpace\"][A];
basis = Orthogonalize[tmp[\"Basis\"]]\
\>", "Input",ExpressionUUID->"261b2273-43f4-4811-8432-0b298fedd278"],

Cell["\<\
Q = Transpose[basis];
Transpose[Q] . Q\
\>", "Input",ExpressionUUID->"ff5a62f2-b810-4e0c-b9ee-0e0e6e305d3e"],

Cell["\<\
A = {{1, 0, 1}, {1, 1, 0}, {0, 1, -1}};
{Qt, R} = QRDecomposition[A]; Q = Transpose[Qt];
{MatrixForm[Q], MatrixForm[R], MatrixForm[Q . R]}\
\>", "Input",ExpressionUUID->"23799ea8-b3d9-4caf-8481-3ae9f85d8772"],

Cell["\<\
A = {{1, 0}, {1, 1}, {0, 1}};
NullSpace[Transpose[A]]\
\>", "Input",ExpressionUUID->"e9fc3696-5821-44ba-8c34-511ee72a26a7"],

Cell["\<\
Clear[a, b, c, d, f, s, t, u, x, y]; A = {{a, b}, {c, d}};
f[x_] := A . x
R = ParametricRegion[{x, y}, {{x, s, s + u}, {y, t, t + u}}];
Rp = TransformedRegion[R, f];
{RegionMeasure[Rp], Abs[Det[A]] u^2}\
\>", "Input",ExpressionUUID->"45844cff-1667-4c6c-b008-3d6c2b7aa83a"]
}, Closed]],

Cell[CellGroupData[{

Cell["19 \:56fa\:6709\:5024\:3068\:56fa\:6709\:30d9\:30af\:30c8\:30eb", \
"Chapter",ExpressionUUID->"5fdfdbe6-fbf3-4041-b841-d7264b4ff40c"],

Cell["\<\
A = {{2, 1}, {4, -1}};
eigs = Eigensystem[A]\
\>", "Input",ExpressionUUID->"662d4806-83dd-4343-afe6-4224745473d2"],

Cell["Solve[Det[x IdentityMatrix[2] - A] == 0, x]", "Input",ExpressionUUID->"afff1b37-9ec0-40c9-b214-5290c35512b7"],

Cell["\<\
Clear[x, y]; Reduce[(3 IdentityMatrix[2] - A) . {x, y} == {0, 0}, {x, y}]\
\>", "Input",ExpressionUUID->"1fdb6304-86ef-4f38-8b3e-02e1821f5ba5"],

Cell["\<\
S = {{2, 2, -2}, {2, 5, -4}, {-2, -4, 5}};
{Q, L, V} = SingularValueDecomposition[S];
{MatrixForm[Q], MatrixForm[L], MatrixForm[Q . L . Transpose[Q]]}\
\>", "Input",ExpressionUUID->"f9366ec7-40ba-4983-b67d-05121bf35321"],

Cell["\<\
S = {{2, 2, -2}, {2, 5, -4}, {-2, -4, 5}};
{vals, vecs} = Eigensystem[S];      (* \:56fa\:6709\:5024\:30fb\:56fa\:6709\
\:30d9\:30af\:30c8\:30eb *)
Q = Transpose[Orthogonalize[vecs]]; (* \:6b63\:898f\:76f4\:4ea4\:306a\:56fa\
\:6709\:30d9\:30af\:30c8\:30eb *)
L = DiagonalMatrix[vals];           (* \:5bfe\:89d2\:884c\:5217 *)
{MatrixForm[Q], MatrixForm[L], MatrixForm[Q . L . Transpose[Q]]}\
\>", "Input",ExpressionUUID->"678a2eeb-2052-451a-a93d-1a3ce72f3648"],

Cell["PositiveSemidefiniteMatrixQ[{{4, 2}, {2, 1}}]", "Input",ExpressionUUID->"8fbb561e-4586-4084-a537-ce55ec24f3fb"],

Cell["\<\
A = {{4, 2}, {2, 1}};
AllTrue[Eigenvalues[A], NonNegative]\
\>", "Input",ExpressionUUID->"b2eda0a2-5aa7-4a76-89f6-af6301e42cfa"],

Cell["\<\
A = {{46, 46}, {46, 86}};
{v1, v2} = Eigenvectors[N[A]][[1]]\
\>", "Input",ExpressionUUID->"74b1c083-e4ba-4e2c-a883-7a300df1f467"],

Cell["\<\
x1 = {1, 3, 6, 10}; y = {7, 1, 6, 14};
X = Transpose[{x1 - Mean[x1], y - Mean[y]}];
A = Transpose[X] . X\
\>", "Input",ExpressionUUID->"68d4c413-5d40-4ee3-aa5a-e1a6ef01a3a1"],

Cell["Reduce[v1 (yp - Mean[y]) == v2 (xp - Mean[x1]), yp] // N", "Input",ExpressionUUID->"32c803e6-f47a-4924-85f9-33cc842f719f"],

Cell["\<\
{U, S, V} = SingularValueDecomposition[X];
V[[All, 1]] // N\
\>", "Input",ExpressionUUID->"0106b77d-e1d5-4cd2-94a1-4eb45ef0c954"]
}, Closed]],

Cell[CellGroupData[{

Cell["20 \:7279\:7570\:5024\:5206\:89e3\:3068\:7591\:4f3c\:9006\:884c\:5217", \
"Chapter",ExpressionUUID->"9b9adeaf-633f-4fac-9fe3-a3148f231cf7"],

Cell["\<\
A = {{1, 0}, {1, 1}, {0, 1}};
{U, S, V} = SingularValueDecomposition[A];
{MatrixForm[U], MatrixForm[S], MatrixForm[Transpose[V]],
 MatrixForm[U . S . Transpose[V]]}\
\>", "Input",ExpressionUUID->"f16c65bd-353e-4c84-a1ad-396a189662f4"],

Cell["\<\
A = {{1, 0}, {1, 1}, {0, 1}};
G = Transpose[A] . A;                                    (* 1 *)
{vals, vecs} = Eigensystem[G];                           (* 2 *)
s = Sqrt[Select[vals, Positive]]; S = DiagonalMatrix[s]; (* 3 *)
r = Length[s];                                           (* 4 *)
Vt = Orthogonalize[Take[vecs, r]]; V = Transpose[Vt];    (* 5 *)
U = A . V . Inverse[S];                                  (* 6 *)
{MatrixForm[U], MatrixForm[S], MatrixForm[Vt], MatrixForm[U . S . Vt]}\
\>", "Input",ExpressionUUID->"92c27d8e-2fd7-4192-bc14-9d452fc1f74e"],

Cell["\<\
A = {{1, 0}, {1, 1}, {0, 1}}; b = {2, 0, 2};
PseudoInverse[A] . b\
\>", "Input",ExpressionUUID->"e63f7f2b-6d7d-4f0d-8ea9-46dcad174f47"]
}, Closed]]
