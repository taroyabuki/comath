Reduce[{D[L, {b}] == {0, 0, 0}}]\
\>", "Input",ExpressionUUID->"a0ae8ee3-e6f3-48c4-85a1-11af53dbc5ee"],

Cell["\<\
D[L, {b}] == -2 Transpose[X] . y + 2 Transpose[X] . X . b // Simplify\
\>", "Input",ExpressionUUID->"431e1087-aeff-4a2f-9a27-4253c773a354"],

Cell["\<\
data = {{1, 2, 3}, {1, 3, 6}, {2, 5, 3}, {3, 7, 6}};
