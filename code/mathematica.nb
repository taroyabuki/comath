\>", "Input",ExpressionUUID->"651187a1-9572-4c9b-96dc-927b1b4d72f2"],

Cell["\<\
A = {{2, 3}, {5, 7}}; b = {1, 3};
A . b\
\>", "Input",ExpressionUUID->"08b9b834-38c9-4849-b514-1a92e94ef4dc"],

Cell["b . A", "Input",ExpressionUUID->"137f4727-15a4-4cd4-aa05-3fce71fe39e6"],

Cell["\<\
Clear[a1, a2, x1, x2, p, q, r, s];
x = {x1, x2}; a = {a1, a2};
G = {{p, q}, {q, s}}; A = {{p, q}, {r, s}};
D[a . x, {x}] == a
D[x . G . x, {x}] == 2 G . x // Simplify
D[(A . x) . (A . x), {x}] == 2 Transpose[A] . A . x // Simplify\
\>", "Input",ExpressionUUID->"4567fe91-e003-4880-beb0-c9cdff7dea73"],

Cell["RegionMeasure[Parallelepiped[{0, 0}, {{3, 1}, {2, 2}}]]", "Input",ExpressionUUID->"2b9f0604-5ed2-4556-9fb4-74634325ce19"],

Cell["\<\
RegionMeasure[Parallelepiped[{0, 0, 0}, {{2, 1, 0}, {0, 2, 1}, {1, 1, 1}}]]\
\>", "Input",ExpressionUUID->"ac4e8b82-c6b2-4aa5-a82d-ec381a53bce5"],

Cell["\<\
A = {{3, 2}, {1, 2}}; b = {8, 4};
Inverse[A] . b\
\>", "Input",ExpressionUUID->"d38a3bcc-812c-42cd-9f7d-613889da75f0"],

Cell["RowReduce[{{4, 2, 8}, {2, 1, 4}}]", "Input",ExpressionUUID->"cb0a6c25-5af6-41ed-8522-950653a85d59"]
}, Closed]],

Cell[CellGroupData[{

Cell["18 \:30d9\:30af\:30c8\:30eb\:7a7a\:9593", "Chapter",ExpressionUUID->"00e0f07a-aece-4c69-88d4-d33df9482413"],

Cell["\<\
a1 = {3, 1}; a2 = {2, 2};
ResourceFunction[\"LinearlyIndependent\"][{a1, a2}]\
\>", "Input",ExpressionUUID->"6273a70c-666f-4ef4-9e6a-8049e7a89d4e"],

Cell["Reduce[c1 a1 + c2 a2 == {0, 0}]", "Input",ExpressionUUID->"2310fa91-7716-4ba1-834d-8998eed9d8f8"],

Cell["\<\
A = {{1, 0, 1}, {1, 1, 0}, {0, 1, -1}};
ResourceFunction[\"ColumnSpace\"][A][\"Basis\"]\
\>", "Input",ExpressionUUID->"003395a0-16ea-4076-a29e-62be587b6611"],

Cell["\<\
A = {{1, 0, 1}, {1, 1, 0}, {0, 1, -1}};
tmp = ResourceFunction[\"ColumnSpace\"][A];
basis = Orthogonalize[tmp[\"Basis\"]]\
\>", "Input",ExpressionUUID->"401bbf0d-8768-4cda-819a-f6c7f03d13b3"],

Cell["\<\
Q = Transpose[basis];
Transpose[Q] . Q\
\>", "Input",ExpressionUUID->"d4e54f35-81e1-48f2-8958-b5df4bb0c21a"],

Cell["\<\
A = {{1, 0, 1}, {1, 1, 0}, {0, 1, -1}};
{Qt, R} = QRDecomposition[A]; Q = Transpose[Qt];
{MatrixForm[Q], MatrixForm[R], MatrixForm[Q . R]}\
\>", "Input",ExpressionUUID->"4a01e807-2f2b-4db3-98c6-f2b2e7cbec8c"],

Cell["\<\
A = {{1, 0}, {1, 1}, {0, 1}};
NullSpace[Transpose[A]]\
\>", "Input",ExpressionUUID->"12f84e36-1a22-4991-b599-d649195c07dc"],

Cell["\<\
Clear[a, b, c, d, f, s, t, u, x, y]; A = {{a, b}, {c, d}};
f[x_] := A . x
R = ParametricRegion[{x, y}, {{x, s, s + u}, {y, t, t + u}}];
Rp = TransformedRegion[R, f];
{RegionMeasure[Rp], Abs[Det[A]] u^2}\
\>", "Input",ExpressionUUID->"4318588b-3b0f-4414-b552-90c48385d8b6"]
}, Closed]],

Cell[CellGroupData[{

Cell["19 \:56fa\:6709\:5024\:3068\:56fa\:6709\:30d9\:30af\:30c8\:30eb", \
"Chapter",ExpressionUUID->"f2d241a3-f0b8-4996-9881-5d8d07b5ae88"],

Cell["\<\
A = {{2, 1}, {4, -1}};
eigs = Eigensystem[A]\
\>", "Input",ExpressionUUID->"c9ece0a2-f1e6-441e-beb5-5f6748d26747"],

Cell["Solve[Det[x IdentityMatrix[2] - A] == 0, x]", "Input",ExpressionUUID->"b19c0351-48d4-4fe7-a707-7cbbe8a6d721"],

Cell["\<\
Clear[x, y]; Reduce[(3 IdentityMatrix[2] - A) . {x, y} == {0, 0}, {x, y}]\
\>", "Input",ExpressionUUID->"81ca55a5-a334-48e9-bff8-efd6c664eb12"],

Cell["\<\
S = {{2, 2, -2}, {2, 5, -4}, {-2, -4, 5}};
{Q, L, V} = SingularValueDecomposition[S];
{MatrixForm[Q], MatrixForm[L], MatrixForm[Q . L . Transpose[Q]]}\
\>", "Input",ExpressionUUID->"a68f8880-a85e-490a-8afe-4430a8b8b49d"],

Cell["\<\
S = {{2, 2, -2}, {2, 5, -4}, {-2, -4, 5}};
{vals, vecs} = Eigensystem[S];      (* \:56fa\:6709\:5024\:30fb\:56fa\:6709\
\:30d9\:30af\:30c8\:30eb *)
Q = Transpose[Orthogonalize[vecs]]; (* \:6b63\:898f\:76f4\:4ea4\:306a\:56fa\
\:6709\:30d9\:30af\:30c8\:30eb *)
L = DiagonalMatrix[vals];           (* \:5bfe\:89d2\:884c\:5217 *)
{MatrixForm[Q], MatrixForm[L], MatrixForm[Q . L . Transpose[Q]]}\
\>", "Input",ExpressionUUID->"20548e1d-980d-4729-ae47-221c0c88cdc5"],

Cell["PositiveSemidefiniteMatrixQ[{{4, 2}, {2, 1}}]", "Input",ExpressionUUID->"19285df2-57ed-43ad-b0ac-aa2027f84477"],

Cell["\<\
A = {{4, 2}, {2, 1}};
AllTrue[Eigenvalues[A], NonNegative]\
\>", "Input",ExpressionUUID->"73ed00a5-7255-4591-ac03-844b4a102cd0"],

Cell["\<\
A = {{46, 46}, {46, 86}};
{v1, v2} = Eigenvectors[N[A]][[1]]\
\>", "Input",ExpressionUUID->"76b1ce54-1526-432a-ab89-3215fffcf661"],

Cell["\<\
x1 = {1, 3, 6, 10}; y = {7, 1, 6, 14};
X = Transpose[{x1 - Mean[x1], y - Mean[y]}];
A = Transpose[X] . X\
\>", "Input",ExpressionUUID->"e6f66da5-8a7e-441c-b8f3-be75258559ce"],

Cell["Reduce[v1 (yp - Mean[y]) == v2 (xp - Mean[x1]), yp] // N", "Input",ExpressionUUID->"d2603238-b2f8-4954-bb50-7a82b3c6b78b"],

Cell["\<\
{U, S, V} = SingularValueDecomposition[X];
V[[All, 1]] // N\
\>", "Input",ExpressionUUID->"e66f6cce-6e29-4466-8a83-c61ce819a741"]
}, Closed]],

Cell[CellGroupData[{

Cell["20 \:7279\:7570\:5024\:5206\:89e3\:3068\:7591\:4f3c\:9006\:884c\:5217", \
"Chapter",ExpressionUUID->"0188b89d-c6eb-4525-9833-219c474071fc"],

Cell["\<\
A = {{1, 0}, {1, 1}, {0, 1}};
{U, S, V} = SingularValueDecomposition[A];
{MatrixForm[U], MatrixForm[S], MatrixForm[Transpose[V]],
 MatrixForm[U . S . Transpose[V]]}\
\>", "Input",ExpressionUUID->"83afa551-913a-4c13-8f17-dcda038d633b"],

Cell["\<\
A = {{1, 0}, {1, 1}, {0, 1}};
G = Transpose[A] . A;                                    (* 1 *)
{vals, vecs} = Eigensystem[G];                           (* 2 *)
s = Sqrt[Select[vals, Positive]]; S = DiagonalMatrix[s]; (* 3 *)
r = Length[s];                                           (* 4 *)
Vt = Orthogonalize[Take[vecs, r]]; V = Transpose[Vt];    (* 5 *)
U = A . V . Inverse[S];                                  (* 6 *)
{MatrixForm[U], MatrixForm[S], MatrixForm[Vt], MatrixForm[U . S . Vt]}\
\>", "Input",ExpressionUUID->"eccb40c7-951e-478e-8338-e21b26c438cd"],

Cell["\<\
A = {{1, 0}, {1, 1}, {0, 1}}; b = {2, 0, 2};
PseudoInverse[A] . b\
\>", "Input",ExpressionUUID->"d46a6c29-35cc-422b-8444-6293604ef90a"]
}, Closed]]
},
