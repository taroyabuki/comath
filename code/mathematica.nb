Cell["\<\
line = Module[{x1, y}, ImplicitRegion[y == b0 + b1 x1, {x1, y}]];
L = Sum[RegionDistance[line, p]^2, {p, Thread[{x1, y}]}];
Minimize[L, {b0, b1}] // Simplify // N\
\>", "Input",ExpressionUUID->"c899abb7-ee41-4168-ae06-d79a304bd3e0"],

Cell["\<\
data = {{1, 2, 3}, {1, 3, 6}, {2, 5, 3}, {3, 7, 6}};
X = DesignMatrix[data, {X1, X2}, {X1, X2}];
y = data[[All, -1]];
Inverse[Transpose[X] . X] . Transpose[X] . y\
\>", "Input",ExpressionUUID->"86122b65-3e4c-4d34-9062-3ce05b072160"],

Cell["PseudoInverse[X] . y", "Input",ExpressionUUID->"4072b9d6-20dd-49c4-b983-bc3b4e2926ae"],

Cell["\<\
b = {b0, b1, b2};
L = (y - X . b) . (y - X . b);
Reduce[{D[L, {b}] == {0, 0, 0}}]\
\>", "Input",ExpressionUUID->"f7aae309-80bb-4888-a144-83b2a96eb1fa"],

Cell["\<\
D[L, {b}] == -2 Transpose[X] . y + 2 Transpose[X] . X . b // Simplify\
\>", "Input",ExpressionUUID->"9453c641-5700-49d7-bfd3-8c01f6f12a5a"],

Cell["\<\
data = {{1, 2, 3}, {1, 3, 6}, {2, 5, 3}, {3, 7, 6}};
model = LinearModelFit[data, {X1, X2}, {X1, X2}];
model[\"RSquared\"]\
\>", "Input",ExpressionUUID->"a652bf6e-d49c-4a0b-b4b4-f05e16f7c71c"],

Cell["\<\
x1 = {1, 3, 6, 10}; y = {7, 1, 6, 14}; data = Thread[{x1, y}];
X = DesignMatrix[data, X1, X1];
yh = X . PseudoInverse[X] . y;
eh = y - yh; fh = yh - Mean[y]; g = y - Mean[y];
R2 = 1 - eh . eh/g . g; N[R2]\
\>", "Input",ExpressionUUID->"30b566be-4d20-413a-918f-6419240fb531"],

Cell["\<\
{Mean[eh] == 0,                            (* \:7279\:5fb41 *)
 Mean[yh] == Mean[y],                      (* \:7279\:5fb42 *)
 g . g == fh . fh + eh . eh,               (* \:7279\:5fb43 *)
 R2 == fh . fh/g . g,                      (* \:7279\:5fb44 *)
 R2 == Correlation[y, yh]^2,               (* \:7279\:5fb45 *)
 0 <= R2 <= 1,                             (* \:7279\:5fb46 *)
 Correlation[y, yh] == Correlation[y, x1]} (* \:7279\:5fb47 *)\
\>", "Input",ExpressionUUID->"e8ceb489-dc3c-4c24-9dfa-996bddb2e0d0"],

Cell["\<\
X = {{1, 1, 2}, {1, 1, 3}, {1, 2, 5}, {1, 3, 7}};
{n, p} = Dimensions[X];
beta = Table[Subscript[\[Beta], i - 1], {i, p}];
epsilon = Table[Subscript[\[Epsilon], i], {i, n}];
Y = X . beta + epsilon;
betah = PseudoInverse[X] . Y // Simplify\
\>", "Input",ExpressionUUID->"ca617c7b-9233-4938-9e3a-d42e30a15bbb"],

Cell["\<\
Clear[sigma];
udist = UniformDistribution[{-Sqrt[3] sigma, Sqrt[3] sigma}];
udists = Table[Distributed[v, udist], {v, epsilon}];
Expectation[betah, udists]\
\>", "Input",ExpressionUUID->"d79b5cf1-b8fd-49a3-8bae-58701e612507"],

Cell["\<\
Z = {{1, 0, 0}, {0, 1, 0}, {0, 0, 1}, {0, 0, 0}};
Cz = Inverse[Transpose[Z] . X] . Transpose[Z];
b = Cz . Y;
Expectation[b, udists]\
\>", "Input",ExpressionUUID->"b300a782-999e-43b7-9e1a-e74939d252f3"],

Cell["\<\
dist1 = TransformedDistribution[b, udists];
dist2 = TransformedDistribution[betah, udists];
Eigenvalues[Covariance[dist1] - Covariance[dist2]]\
\>", "Input",ExpressionUUID->"40bc2f19-8de0-498c-a83c-8b459d6cc9d1"],

Cell["\<\
Variance[dist1]
Variance[dist2]\
\>", "Input",ExpressionUUID->"a468e8fb-ac9a-45c3-a87c-a5c2c9be042b"],

Cell["\<\
ndist = NormalDistribution[0, sigma];
ndists = Table[Distributed[v, ndist], {v, epsilon}];
TransformedDistribution[betah, ndists] ==
 MultinormalDistribution[beta, sigma^2 Inverse[Transpose[X] . X]]\
\>", "Input",ExpressionUUID->"597c878e-be7a-471e-9fc1-47dcd53963c5"],

Cell["\<\
data = {{1, 2, 3}, {1, 3, 6}, {2, 5, 3}, {3, 7, 6}};
model = LinearModelFit[data, {X1, X2}, {X1, X2}];
model[\"EstimatedVariance\"]\
\>", "Input",ExpressionUUID->"8bae3fa8-9515-48de-9fc4-627ba8ec5aac"],

Cell["\<\
e = Y - X . betah; RSS = e . e;
s2 = RSS/(n - p) // Simplify\
\>", "Input",ExpressionUUID->"2731581f-481e-428a-ac8a-43c4394352f1"],

Cell["Expectation[s2, udists]", "Input",ExpressionUUID->"7384d854-87a9-4fcd-a7ca-5a53ad6e8e52"],

Cell["\<\
tmp = Block[{sigma = 2},
   dist = TransformedDistribution[(n - p) s2/sigma^2, ndists];
   RandomVariate[dist, 10000]];
cdist = ChiSquareDistribution[n - p];
Show[Histogram[tmp, Automatic, \"PDF\"],
 Plot[PDF[cdist][x], {x, 0, 5}, PlotRange -> {0, 2}]]\
\>", "Input",ExpressionUUID->"7e345624-4971-4265-837b-e3b702e8ec5f"],

Cell["\<\
n := Length[data]; p := Length[data[[1]]]; Clear[x];
vars := Table[Subscript[x, i], {i, p - 1}]
X := DesignMatrix[data, vars, vars]; y := data[[All, -1]]
yh := X . PseudoInverse[X] . y; e := y - yh;

data = {{1, 2, 3}, {1, 3, 6}, {2, 5, 3}, {3, 7, 6}};
Module[{F, fdist},
  F = Total[(yh - Mean[y])^2]/(p - 1)/(e . e/(n - p));
  fdist = FRatioDistribution[p - 1, n - p];
  {F, 1 - CDF[fdist][F]}] // N\
\>", "Input",ExpressionUUID->"bbcc95d4-b35a-423e-b738-287c2885948a"],

Cell["\<\
betah := PseudoInverse[X] . y; uh := Transpose[A] . betah
M := Transpose[A] . Inverse[Transpose[X] . X] . A
r := MatrixRank[A]
RSS := e . e; s2 := RSS/(n - p)
F := ((uh - u) . Inverse[M] . (uh - u)/r)/s2
fdist := FRatioDistribution[r, n - p]
pvalue := 1 - CDF[fdist, F]

A = Transpose[{{0, 1, 0}, {0, 0, 1}}]; u = {0, 0};
{F, pvalue} // N\
\>", "Input",ExpressionUUID->"81eade31-4e18-4330-ad54-d6426c5dd6e1"],

Cell["\<\
model := LinearModelFit[data, vars, vars]
model[\"ParameterTable\"]\
\>", "Input",ExpressionUUID->"6a5efe35-bf7a-4cd9-983f-5f721e331985"],

Cell["\<\
u = {0};
A = Transpose[{{1, 0, 0}}]; pvalue // N (* k = 0 *)
A = Transpose[{{0, 1, 0}}]; pvalue // N (* k = 1 *)
A = Transpose[{{0, 0, 1}}]; pvalue // N (* k = 2 *)\
\>", "Input",ExpressionUUID->"1911a55d-2266-4b4a-9ccd-33097753f586"],

Cell["\<\
s := Sqrt[s2 Diagonal[Inverse[Transpose[X] . X]]]
s // N\
\>", "Input",ExpressionUUID->"6965d1ac-ad96-436a-a8b1-d3617fea34ba"],

Cell["\<\
t := betah/s
t // N\
\>", "Input",ExpressionUUID->"afa59fb3-77dd-4a6e-86c5-f6a231f53713"],

Cell["\<\
tdist := StudentTDistribution[n - p]
Table[2 Min[CDF[tdist][v], 1 - CDF[tdist][v]], {v, t}] // N\
\>", "Input",ExpressionUUID->"6b4f4400-7897-4a75-b0e5-fd25f7b26378"],

Cell["\<\
