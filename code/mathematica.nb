y = data[[All, -1]];
Inverse[Transpose[X] . X] . Transpose[X] . y\
\>", "Input",ExpressionUUID->"2ceac75a-41c2-49ab-9bbe-a62e3bab9f41"],

Cell["PseudoInverse[X] . y", "Input",ExpressionUUID->"106c2d31-d987-4456-bde4-a8963bbdd83d"],

Cell["\<\
