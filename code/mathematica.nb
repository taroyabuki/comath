g1 = Graphics[{Gray, Apply[Rectangle, Transpose[tmp]]}];
g2 = Graphics[model[\"ParameterConfidenceRegion\", level]];
Show[g1, g2, AspectRatio -> 1, Frame -> True]\
\>", "Input",ExpressionUUID->"dff6afac-5de9-4c73-80b3-370e2ce15741"],

Cell["\<\
