Cell["\<\
A = {{2, 3}, {5, 7}}; B = {{1, 2}, {3, 4}};
A . B\
\>", "Input",ExpressionUUID->"3b8bce42-99da-404e-8f30-d834b1d9992c"],

Cell["\<\
A = {{2, 3}, {5, 7}}; b = {1, 3};
A . b\
\>", "Input",ExpressionUUID->"c7d39fec-109f-4904-a625-df1d8263c583"],

Cell["b . A", "Input",ExpressionUUID->"a75733f2-58ca-4709-8449-9b48559c6af4"],

Cell["\<\
Clear[a1, a2, x1, x2, p, q, r, s];
x = {x1, x2}; a = {a1, a2};
G = {{p, q}, {q, s}}; A = {{p, q}, {r, s}};
D[a . x, {x}] == a
D[x . G . x, {x}] == 2 G . x // Simplify
D[(A . x) . (A . x), {x}] == 2 Transpose[A] . A . x // Simplify\
\>", "Input",ExpressionUUID->"61c0fe5f-aed9-431c-9ce4-a105aff6b4b7"],

Cell["RegionMeasure[Parallelepiped[{0, 0}, {{3, 1}, {2, 2}}]]", "Input",ExpressionUUID->"c5b5b8fe-5f46-4a6d-8150-14468f591a24"],

Cell["\<\
