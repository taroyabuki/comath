A = {{2, 3}, {5, 7}}; B = {{1, 2}, {3, 4}};
A . B\
\>", "Input",ExpressionUUID->"48eeb5d2-3e8f-41ed-8d46-63ea870fc8c7"],

Cell["\<\
A = {{2, 3}, {5, 7}}; b = {1, 3};
A . b\
\>", "Input",ExpressionUUID->"09bc75ab-3a1c-4306-a3f3-74c28103349a"],

Cell["b . A", "Input",ExpressionUUID->"b4a8e762-63a2-4c90-8090-92578f0161a7"],

Cell["\<\
Clear[a1, a2, x1, x2, p, q, r, s];
x = {x1, x2}; a = {a1, a2};
G = {{p, q}, {q, s}}; A = {{p, q}, {r, s}};
D[a . x, {x}] == a
D[x . G . x, {x}] == 2 G . x // Simplify
D[(A . x) . (A . x), {x}] == 2 Transpose[A] . A . x // Simplify\
\>", "Input",ExpressionUUID->"afb4703b-c908-43b6-b6d2-0e2a31a83838"],

Cell["RegionMeasure[Parallelepiped[{0, 0}, {{3, 1}, {2, 2}}]]", "Input",ExpressionUUID->"8370aeda-062b-4920-bbf2-f572f98ef5d5"],

Cell["\<\
RegionMeasure[Parallelepiped[{0, 0, 0}, {{2, 1, 0}, {0, 2, 1}, {1, 1, 1}}]]\
\>", "Input",ExpressionUUID->"80ed8092-e0be-47c6-a474-9bef7b7d124b"],

Cell["\<\
A = {{3, 2}, {1, 2}}; b = {8, 4};
Inverse[A] . b\
\>", "Input",ExpressionUUID->"bf10a84c-66a2-4e48-bb52-001e50acea83"],

Cell["RowReduce[{{4, 2, 8}, {2, 1, 4}}]", "Input",ExpressionUUID->"1c49f1f1-8536-44b7-ab09-e53ee6dfc0d2"]
}, Closed]],

Cell[CellGroupData[{

Cell["18 \:30d9\:30af\:30c8\:30eb\:7a7a\:9593", "Chapter",ExpressionUUID->"98a3c9e4-336c-48c6-8278-679c4c9ea987"],

Cell["\<\
a1 = {3, 1}; a2 = {2, 2};
ResourceFunction[\"LinearlyIndependent\"][{a1, a2}]\
\>", "Input",ExpressionUUID->"4e55fcdd-3b68-4b5d-87ae-291951bc4bb0"],

Cell["Reduce[c1 a1 + c2 a2 == {0, 0}]", "Input",ExpressionUUID->"2e4ca8fa-1201-4cfb-b28d-7ef4263c556d"],

Cell["\<\
A = {{1, 0, 1}, {1, 1, 0}, {0, 1, -1}};
ResourceFunction[\"ColumnSpace\"][A][\"Basis\"]\
\>", "Input",ExpressionUUID->"a5c5c341-d67c-4080-af58-5009501712b6"],

Cell["\<\
A = {{1, 0, 1}, {1, 1, 0}, {0, 1, -1}};
tmp = ResourceFunction[\"ColumnSpace\"][A];
basis = Orthogonalize[tmp[\"Basis\"]]\
\>", "Input",ExpressionUUID->"09841514-e0c6-4cca-b820-1715ea45dee6"],

Cell["\<\
Q = Transpose[basis];
Transpose[Q] . Q\
\>", "Input",ExpressionUUID->"e0bdee19-af59-46ff-ad38-c6254a176a2c"],

Cell["\<\
A = {{1, 0, 1}, {1, 1, 0}, {0, 1, -1}};
{Qt, R} = QRDecomposition[A];
{MatrixForm[Transpose[Qt]], MatrixForm[R]}\
\>", "Input",ExpressionUUID->"15b51e31-a61c-426f-a929-740768f21b34"],

Cell["A == Q . R", "Input",ExpressionUUID->"349aaf3a-1a3d-4e90-bd66-2bfdac99984c"],

Cell["\<\
A = {{1, 0}, {1, 1}, {0, 1}};
NullSpace[Transpose[A]]\
\>", "Input",ExpressionUUID->"b25ead87-65ad-4e21-8eb8-49318df1c577"],

Cell["\<\
Clear[a, b, c, d, f, s, t, u, x, y]; A = {{a, b}, {c, d}};
f[x_] := A . x
R = ParametricRegion[{x, y}, {{x, s, s + u}, {y, t, t + u}}];
Rp = TransformedRegion[R, f];
{RegionMeasure[Rp], Abs[Det[A]] u^2}\
\>", "Input",ExpressionUUID->"ee6bf78f-4649-40fc-bbf8-d458dedf1ff0"]
}, Closed]],

Cell[CellGroupData[{

Cell["19 \:56fa\:6709\:5024\:3068\:56fa\:6709\:30d9\:30af\:30c8\:30eb", \
"Chapter",ExpressionUUID->"2f523bc2-fdf9-4423-9166-34ab17101d2e"],

Cell["\<\
A = {{2, 1}, {4, -1}};
eigs = Eigensystem[A]\
\>", "Input",ExpressionUUID->"ebbd03a9-c8e0-421c-bd37-c8b85dc206bd"],

Cell["Solve[Det[x IdentityMatrix[2] - A] == 0, x]", "Input",ExpressionUUID->"0588b2bb-9413-40a5-89d3-d622e4aeedc5"],

Cell["\<\
Clear[x, y]; Reduce[(3 IdentityMatrix[2] - A) . {x, y} == {0, 0}, {x, y}]\
\>", "Input",ExpressionUUID->"b2f299de-cbc3-4fb8-9ec1-27fc4317d428"],

Cell["\<\
S = {{2, 2, -2}, {2, 5, -4}, {-2, -4, 5}};
{Q, L, V} = SingularValueDecomposition[S];
S == Q . L . Transpose[V] == Q . L . Transpose[Q]\
\>", "Input",ExpressionUUID->"80f1814b-81c6-4266-848b-93a21b43dc30"],

Cell["\<\
S = {{2, 2, -2}, {2, 5, -4}, {-2, -4, 5}};
{vals, vecs} = Eigensystem[S];      (* \:56fa\:6709\:5024\:30fb\:56fa\:6709\
\:30d9\:30af\:30c8\:30eb *)
Q = Transpose[Orthogonalize[vecs]]; (* \:6b63\:898f\:76f4\:4ea4\:306a\:56fa\
\:6709\:30d9\:30af\:30c8\:30eb *)
L = DiagonalMatrix[vals];           (* \:5bfe\:89d2\:884c\:5217 *)
S == Q . L . Transpose[Q]\
\>", "Input",ExpressionUUID->"d0944fa6-8764-4c47-8f60-f47339623fd8"],

Cell["PositiveSemidefiniteMatrixQ[{{4, 2}, {2, 1}}]", "Input",ExpressionUUID->"09019045-c5e9-4ca1-84d9-2322cb926d5a"],

Cell["\<\
A = {{4, 2}, {2, 1}};
AllTrue[Eigenvalues[A], NonNegative]\
\>", "Input",ExpressionUUID->"6eb41edc-b846-4d0a-aafc-c6114cfa1f63"],

Cell["\<\
A = {{46, 46}, {46, 86}};
{v1, v2} = Eigenvectors[N[A]][[1]]\
\>", "Input",ExpressionUUID->"eaf056a0-76f9-440b-9e60-dfb4f154ab5c"],

Cell["\<\
x1 = {1, 3, 6, 10}; y = {7, 1, 6, 14};
X = Transpose[{x1 - Mean[x1], y - Mean[y]}];
A = Transpose[X] . X\
\>", "Input",ExpressionUUID->"8265c694-054a-44af-a40c-7bab10349043"],

Cell["Reduce[v1 (yp - Mean[y]) == v2 (xp - Mean[x1]), yp] // N", "Input",ExpressionUUID->"b0c0e9e7-f12b-4a86-965d-f79397ff9944"],

Cell["\<\
X = {{-4, 0}, {-2, -6}, {1, -1}, {5, 7}};
{U, S, V} = SingularValueDecomposition[X];
V[[All, 1]] // N\
\>", "Input",ExpressionUUID->"f21c4e93-184b-42f8-81a7-ef4732204a57"]
}, Closed]],

Cell[CellGroupData[{

Cell["20 \:7279\:7570\:5024\:5206\:89e3\:3068\:7591\:4f3c\:9006\:884c\:5217", \
"Chapter",ExpressionUUID->"6e49661a-d0ae-4108-8dc1-564614ef1932"],

Cell["\<\
A = {{1, 0}, {1, 1}, {0, 1}};
{U, S, V} = SingularValueDecomposition[A];
{MatrixForm[U], MatrixForm[S], MatrixForm[Transpose[V]]}\
\>", "Input",ExpressionUUID->"cf0feffb-74b7-4289-bf69-ce3826ca08c3"],

Cell["A == U . S . Transpose[V]", "Input",ExpressionUUID->"57032099-e6c4-4cec-813d-ce20efe88284"],

Cell["\<\
A = {{1, 0}, {1, 1}, {0, 1}};
G = Transpose[A] . A;                                    (* 1 *)
{vals, vecs} = Eigensystem[G];                           (* 2 *)
s = Sqrt[Select[vals, Positive]]; S = DiagonalMatrix[s]; (* 3 *)
r = Length[s];                                           (* 4 *)
Vt = Orthogonalize[Take[vecs, r]]; V = Transpose[Vt];    (* 5 *)
U = A . V . Inverse[S];                                  (* 6 *)
{MatrixForm[U], MatrixForm[S], MatrixForm[Vt], MatrixForm[U . S . Vt]}\
\>", "Input",ExpressionUUID->"7fe40997-a5e3-4156-a231-5788e97e5504"],

Cell["\<\
A = {{1, 0}, {1, 1}, {0, 1}}; b = {2, 0, 2};
PseudoInverse[A] . b\
\>", "Input",ExpressionUUID->"8a51bf35-c909-4855-ac02-8a93c07813fe"]
}, Closed]]
},
